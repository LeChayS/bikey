@page
@model bikey.Pages.History.OrderDetailModel
@{
    ViewData["Title"] = "Chi tiết đơn đặt chỗ";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/orderdetail.css" asp-append-version="true" />
}

<div class="wrapper container">

    <div class="container-header">
        <div class="contract-header">
            <div class="contract-number">
                DC<strong>@(Model.Order.MaDatCho.ToString("D6"))</strong>
            </div>
            <div class="contract-status">
                <strong>
                    @{
                        var statusClass = Model.Order.TrangThai switch
                        {
                            "Chờ xác nhận" => "text-warning",
                            "Hủy" => "text-danger",
                            "Đã xử lý" => "text-success",
                            _ => "text-info"
                        };
                    }
                    <span class="@statusClass">@Model.Order.TrangThai</span>
                </strong>
            </div>
            <p class="mb-0 mt-3">Ngày tạo: <strong>@Model.Order.NgayDat.ToString("dd/MM/yyyy HH:mm")</strong></p>
        </div>
    </div>

    <div class="container-grid">
        @* left *@
        <div>
            <div class="container-fluid">

                @* thông tin khách *@
                <div class="cus-info">
                    <h2 class="title">
                        <i class="bi bi-people" aria-hidden="true"></i>
                        Thông tin khách hàng
                    </h2>
                    <div class="info-body">
                        <div class="body-grid-cus mb-3">
                            <div class="info-line">
                                <span class="info-label">Họ tên</span>
                                <span class="info-value">@Model.Order.HoTen</span>
                            </div>
                            <div class="info-line">
                                <span class="info-label">Số điện thoại</span>
                                <span class="info-value">@Model.Order.SoDienThoai</span>
                            </div>
                            <div class="info-line">
                                <span class="info-label">Email</span>
                                <span class="info-value">@Model.Order.Email</span>
                            </div>
                            <div class="info-line">
                                <span class="info-label">Số căn cước</span>
                                <span class="info-value">@Model.Order.SoCanCuoc</span>
                            </div>
                        </div>
                        <div class="info-line">
                            <span class="info-label">Địa chỉ</span>
                            <span class="info-value">@Model.Order.DiaChi</span>
                        </div>
                    </div>
                </div>

                <div class="vehicle-info">
                    <h2 class="title">
                        <i class="bi bi-scooter" aria-hidden="true"></i>
                        Thông tin xe thuê
                    </h2>

                    <div class="info-body">
                        <div class="info-top">
                            <h3 class="info-name">
                                @Model.Order.Xe.TenXe<span class="info-plate"> —
                                    @Model.Order.Xe.BienSoXe</span>
                            </h3>
                        </div>

                        <div class="body-grid-veh">
                            <div class="info-media">
                                @if (!string.IsNullOrWhiteSpace(Model.Order.Xe.HinhAnhHienThi))
                                {
                                    <div class="col-12">
                                        <img src="/@Model.Order.Xe.HinhAnhHienThi.TrimStart('~', '/')"
                                            alt="@Model.Order.Xe.TenXe" class="img-fluid rounded"
                                            style="max-height: 250px; object-fit: cover;" />
                                    </div>
                                }
                                else
                                {
                                    <div class="media-placeholder" aria-hidden="true">
                                        <i class="bi bi-scooter"></i>
                                    </div>
                                }
                            </div>
                            <div class="info-details">
                                <div class="info-line">
                                    <span class="info-label">Hãng xe</span>
                                    <span class="info-value">@Model.Order.Xe.HangXe</span>
                                </div>
                                <div class="info-line">
                                    <span class="info-label">Dòng xe</span>
                                    <span class="info-value">@Model.Order.Xe.DongXe</span>
                                </div>
                            </div>
                            <div class="info-details">
                                <div class="info-line">
                                    <span class="info-label">Loại xe</span>
                                    <span class="info-value">@(Model.Order.Xe.LoaiXe?.TenLoaiXe ?? "—")</span>
                                </div>
                                <div class="info-line">
                                    <span class="info-label">Giá thuê/ngày</span>
                                    <span class="info-value">@Model.Order.Xe.GiaThue.ToString("N0") VNĐ</span>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Order.GhiChu))
                {
                    <div class="note-info">
                        <h2 class="title">
                            <i class="bi bi-chat-left-text" aria-hidden="true"></i>
                            Ghi chú
                        </h2>
                        <div class="info-body">
                            <p class="mb-0">@Model.Order.GhiChu</p>
                        </div>
                    </div>
                }
            </div>
        </div>


        @* right *@
        <div>
            <div class="container-fluid">

                <h2 class="title">
                    <i class="bi bi-file-earmark-text" aria-hidden="true"></i> Thông tin đơn
                </h2>

                <div class="info-body">
                    <div class="info-row">
                        <div class="info-label">Ngày nhận xe</div>
                        <div class="info-value">@Model.Order.NgayNhanXe.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Ngày trả xe</div>
                        <div class="info-value">@Model.Order.NgayTraXe.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Số ngày thuê</div>
                        <div class="info-value">@Model.Order.SoNgayThue ngày</div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Tổng tiền dự kiến</div>
                        <div class="info-value">
                            <strong class="text-primary fs-5">@Model.Order.TongTienDuKien.ToString("N0") VNĐ</strong>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <a asp-page="/Account/Orders" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
