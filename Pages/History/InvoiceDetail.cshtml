@page
@model bikey.Pages.History.InvoiceDetailModel
@{
    ViewData["Title"] = "Chi tiết hóa đơn thanh toán";
}

<section class="account-page py-5">
    <div class="container">
        <div class="account-panel">
            <div class="account-panel__header">
                <h1>Chi tiết hóa đơn thanh toán</h1>
                <p>Mã hóa đơn: <strong>INV-@Model.Invoice.MaHoaDon.ToString("D5")</strong></p>
            </div>

            <div class="mt-4">
                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <h3 class="card-title mb-4">
                                    <i class="bi bi-receipt"></i> Thông tin hóa đơn
                                </h3>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="profile-item">
                                            <span>Mã hợp đồng</span>
                                            <strong>HD-@Model.Contract.MaHopDong.ToString("D5")</strong>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="profile-item">
                                            <span>Ngày thanh toán</span>
                                            <strong>@Model.Invoice.NgayThanhToan.ToString("dd/MM/yyyy")</strong>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="profile-item">
                                            <span>Ngày tạo hóa đơn</span>
                                            <strong>@Model.Invoice.NgayTao.ToString("dd/MM/yyyy HH:mm")</strong>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="profile-item">
                                            <span>Trạng thái</span>
                                            <strong>
                                                <span class="text-success">@Model.Invoice.TrangThai</span>
                                            </strong>
                                        </div>
                                    </div>
                                    @if (Model.Invoice.NguoiTao != null)
                                    {
                                        <div class="col-md-6">
                                            <div class="profile-item">
                                                <span>Người tạo</span>
                                                <strong>@Model.Invoice.NguoiTao.Ten</strong>
                                            </div>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(Model.Invoice.GhiChu))
                                    {
                                        <div class="col-12">
                                            <div class="profile-item">
                                                <span>Ghi chú</span>
                                                <strong>@Model.Invoice.GhiChu</strong>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="card shadow-sm mt-4">
                            <div class="card-body">
                                <h3 class="card-title mb-4">
                                    <i class="bi bi-person-vcard"></i> Thông tin khách hàng
                                </h3>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="profile-item">
                                            <span>Họ tên</span>
                                            <strong>@Model.Contract.HoTenKhach</strong>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="profile-item">
                                            <span>Số điện thoại</span>
                                            <strong>@Model.Contract.SoDienThoai</strong>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="profile-item">
                                            <span>CCCD/CMND</span>
                                            <strong>@Model.Contract.SoCCCD</strong>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="profile-item">
                                            <span>Địa chỉ</span>
                                            <strong>@Model.Contract.DiaChi</strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow-sm mt-4">
                            <div class="card-body">
                                <h3 class="card-title mb-4">
                                    <i class="bi bi-list-check"></i> Chi tiết xe thuê
                                </h3>
                                @if (Model.Contract.ChiTietHopDong.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover">
                                            <thead>
                                                <tr>
                                                    <th>Tên xe</th>
                                                    <th>Biển số</th>
                                                    <th>Giá thuê/ngày</th>
                                                    <th>Số ngày</th>
                                                    <th>Thành tiền</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var ct in Model.Contract.ChiTietHopDong)
                                                {
                                                    <tr>
                                                        <td>@ct.Xe?.TenXe</td>
                                                        <td>@ct.Xe?.BienSoXe</td>
                                                        <td>@ct.GiaThueNgay.ToString("N0") đ</td>
                                                        <td>@ct.SoNgayThueTinhToan</td>
                                                        <td>@ct.ThanhTienTinhToan.ToString("N0") đ</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <h3 class="card-title mb-4">
                                    <i class="bi bi-calendar-check"></i> Thời gian thuê
                                </h3>
                                <div class="profile-item">
                                    <span>Ngày nhận xe</span>
                                    <strong>@Model.Contract.NgayNhanXe.ToString("dd/MM/yyyy")</strong>
                                </div>
                                <div class="profile-item">
                                    <span>Ngày trả xe dự kiến</span>
                                    <strong>@Model.Contract.NgayTraXeDuKien.ToString("dd/MM/yyyy")</strong>
                                </div>
                                @if (Model.Contract.NgayTraXeThucTe.HasValue)
                                {
                                    <div class="profile-item">
                                        <span>Ngày trả xe thực tế</span>
                                        <strong>@Model.Contract.NgayTraXeThucTe.Value.ToString("dd/MM/yyyy")</strong>
                                    </div>
                                }
                                <div class="profile-item">
                                    <span>Số ngày thuê</span>
                                    <strong>@Model.Contract.SoNgayThue ngày</strong>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow-sm mt-3 border-primary">
                            <div class="card-body">
                                <h3 class="card-title mb-4 text-primary">
                                    <i class="bi bi-cash-stack"></i> Tổng kết thanh toán
                                </h3>
                                <div class="profile-item">
                                    <span>Tổng tiền xe</span>
                                    <strong>@Model.Contract.TongTienXe.ToString("N0") đ</strong>
                                </div>
                                <div class="profile-item">
                                    <span>Phụ phí</span>
                                    <strong>@Model.Contract.PhuPhi.ToString("N0") đ</strong>
                                </div>
                                <div class="profile-item">
                                    <span>Tiền cọc</span>
                                    <strong>@Model.Contract.TienCoc.ToString("N0") đ</strong>
                                </div>
                                <hr class="border-primary" />
                                <div class="profile-item">
                                    <span class="fw-bold">Tổng hợp đồng</span>
                                    <strong>@Model.Contract.TongTien.ToString("N0") đ</strong>
                                </div>
                                <hr class="border-primary" />
                                <div class="profile-item">
                                    <span class="fw-bold fs-5">Đã thanh toán</span>
                                    <strong class="text-success fs-4">@Model.Invoice.SoTien.ToString("N0") VNĐ</strong>
                                </div>
                            </div>
                        </div>

                        <div class="mt-3">
                            <a asp-page="/Account/Orders" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-arrow-left"></i> Quay lại danh sách
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
