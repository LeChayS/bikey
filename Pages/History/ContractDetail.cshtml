@page
@model bikey.Pages.History.ContractDetailModel
@{
    ViewData["Title"] = "Chi tiết hợp đồng thuê xe";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/contractdetail.css" asp-append-version="true" />
}



<div class="wrapper container">
    <div class="container-header">
        <div class="contract-header">
            <div class="contract-number">
                <i class="bi bi-file-earmark-text"></i> HD<strong>@(Model.Contract.MaHopDong.ToString("D6"))</strong>
            </div>
            <div class="contract-status">
                @Model.Contract.TrangThai
            </div>
            @if (Model.Order?.TrangThai == "Đang giữ chỗ")
            {
                <div class="alert alert-info mt-3 mb-0">
                    <i class="bi bi-info-circle"></i> Đơn đặt của bạn đã được duyệt. Vui lòng đến nhận xe đúng ngày.
                </div>
            }
            <p class="mb-0 mt-3">Ngày tạo: <strong>@Model.Contract.NgayTao.ToString("dd/MM/yyyy HH:mm")</strong></p>
        </div>
    </div>



    <div class="container-grid">
        @* left *@
        <div>
            <!-- Thông tin khách hàng -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-person-fill"></i> Thông tin khách hàng
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Họ và tên</div>
                            <div class="info-value">@Model.Contract.HoTenKhach</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Số điện thoại</div>
                            <div class="info-value">@Model.Contract.SoDienThoai</div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">CCCD/CMND</div>
                            <div class="info-value">@Model.Contract.SoCCCD</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Địa chỉ</div>
                            <div class="info-value">@Model.Contract.DiaChi</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Thông tin xe -->
            <div class="info-section">
                <h3 class="section-title mb-0">
                    <i class="bi bi-bicycle"></i> Thông tin xe thuê
                </h3>

                @if (Model.Contract.ChiTietHopDong?.Any() == true)
                {
                    foreach (var chiTiet in Model.Contract.ChiTietHopDong)
                    {
                        <div class="vehicle-card">
                            <div class="vehicle-header">
                                <div style="font-size: 20px;">
                                    <strong>@(chiTiet.Xe?.TenXe ?? "—") - @(chiTiet.Xe?.BienSoXe ?? "—")</strong>
                                </div>
                                <div>@(chiTiet.Xe?.HangXe ?? "—") - @(chiTiet.Xe?.DongXe ?? "—")</div>
                            </div>
                            <div class="vehicle-body">
                                <div class="vehicle-info-grid">
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Giá thuê/ngày</div>
                                        <div class="vehicle-info-value">@chiTiet.GiaThueNgay.ToString("N0")đ</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Số ngày thuê</div>
                                        <div class="vehicle-info-value">@chiTiet.SoNgayThueTinhToan ngày</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Thành tiền</div>
                                        <div class="vehicle-info-value">@chiTiet.ThanhTienTinhToan.ToString("N0")đ</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Tình trạng</div>
                                        <div class="vehicle-info-value">
                                            @if (string.Equals(chiTiet.TinhTrangTraXe, "Bình thường",
                                                                                StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="status-badge status-completed">Bình thường</span>
                                            }
                                            else if (string.Equals(chiTiet.TinhTrangTraXe, "Có sự cố",
                                            StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="status-badge status-problem">Có sự cố</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-renting">Đang thuê</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-exclamation-triangle"></i> Chưa có thông tin xe
                    </div>
                }
            </div>

            <!-- Ghi chú thuê -->
            @if (!string.IsNullOrWhiteSpace(Model.Contract.GhiChu))
            {
                <div class="info-section">
                    <h3 class="section-title">
                        <i class="bi bi-chat-left-text"></i> Ghi chú thuê
                    </h3>
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle"></i> @Model.Contract.GhiChu
                    </div>
                </div>
            }
        </div>

        @* right *@
        <div>
            <!-- Thời gian thuê -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-calendar-range"></i> Thời gian thuê
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày nhận xe</div>
                            <div class="info-value">@Model.Contract.NgayNhanXe.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày trả xe dự kiến</div>
                            <div class="info-value">@Model.Contract.NgayTraXeDuKien.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    @if (Model.Contract.NgayTraXeThucTe.HasValue)
                    {
                        <div class="col-md-6">
                            <div class="info-row">
                                <div class="info-label">Ngày trả xe thực tế</div>
                                <div class="info-value">@Model.Contract.NgayTraXeThucTe.Value.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>
                    }
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Tổng số ngày thuê</div>
                            <div class="info-value">
                                @{
                                    var tongNgayThue = Model.Contract.NgayTraXeThucTe.HasValue
                                    ? Math.Max(1, (Model.Contract.NgayTraXeThucTe.Value.Date -
                                    Model.Contract.NgayNhanXe.Date).Days)
                                    : Math.Max(1, (Model.Contract.NgayTraXeDuKien.Date -
                                    Model.Contract.NgayNhanXe.Date).Days);
                                }
                                @tongNgayThue ngày
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="financial-summary">
                <div class="financial-row">
                    <span>Tiền thuê xe:</span>
                    <span>@Model.Contract.TongTienXe.ToString("N0")đ</span>
                </div>
                <div class="financial-row">
                    <span>Tiền cọc:</span>
                    <span>@Model.Contract.TienCoc.ToString("N0")đ</span>
                </div>
                <div class="financial-row">
                    <span>Phụ phí:</span>
                    <span>@Model.Contract.PhuPhi.ToString("N0")đ</span>
                </div>
                <div class="financial-row">
                    <span>Phí đền bù:</span>
                    <span>@Model.Contract.TongPhiDenBu.ToString("N0")đ</span>
                </div>
                <div class="financial-row financial-total">
                    <span>Tổng cộng:</span>
                    <span>@Model.Contract.TongTien.ToString("N0")đ</span>
                </div>
            </div>
            <a asp-page="/Account/Orders" class="btn btn-outline-secondary w-100">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    </div>

</div>

