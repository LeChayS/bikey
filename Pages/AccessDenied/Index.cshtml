@page "/AccessDenied"
@model bikey.Pages.AccessDenied.IndexModel
@{
    Layout = null;
    ViewData["Title"] = "Không có quyền truy cập";

    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
    var isStaffOrAdmin = userRole == "Admin" || userRole == "Staff";

    string title, message;
    if (isStaffOrAdmin)
    {
        title = "Không có quyền truy cập";
        message = "Bạn không được phép truy cập vào trang này vì chưa được cấp quyền. Vui lòng liên hệ với quản trị viên để được hỗ trợ.";
    }
    else
    {
        title = "Không thể vào trang quản trị";
        message = "Tài khoản của bạn có vai trò <strong>Khách hàng (User)</strong> và không được phép truy cập khu vực dành cho quản trị viên hoặc nhân viên (Staff).";
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bikey</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/shared/access-denied.css" asp-append-version="true" />
</head>
<body>
    <div id="access-denied-root">
        <div class="access-denied-page">
            <div class="container access-denied-page__inner">
                <div class="access-denied-card">
                    <div class="access-denied-card__icon" aria-hidden="true">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <p class="access-denied-card__eyebrow">Truy cập bị từ chối</p>
                    <h1 class="access-denied-card__title">@title</h1>
                    <p class="access-denied-card__text">
                        @Html.Raw(message)
                    </p>
                    <div class="access-denied-card__actions">
                        @if (isStaffOrAdmin)
                        {
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-primary">
                                <i class="bi bi-speedometer2"></i> Về Dashboard
                            </a>
                        }
                        else
                        {
                            <a asp-controller="TrangChu" asp-action="Index" class="btn btn-primary">
                                <i class="bi bi-house-door"></i> Về trang chủ
                            </a>
                        }
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-secondary">
                                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
