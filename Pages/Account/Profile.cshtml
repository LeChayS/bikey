@page
@model bikey.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Chinh sua thong tin";
}

<section class="account-page py-5">
    <div class="container">
        <div class="account-panel">
            <div class="account-panel__header">
                <span class="eyebrow">Thông tin cá nhân</span>
                <h1>Chỉnh sửa thông tin</h1>
                <p>Cập nhật thông tin cá nhân của bạn.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="alert alert-success mt-4" role="alert">
                    @Model.StatusMessage
                </div>
            }

            <form method="post" class="account-form mt-4">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="account-form-grid">
                    <div>
                        <label for="Input_HoTen" class="form-label">@Html.DisplayNameFor(model => model.Input.HoTen)</label>
                        <input asp-for="Input.HoTen" class="form-control form-control-lg" />
                        <span asp-validation-for="Input.HoTen" class="text-danger"></span>
                    </div>

                    <div>
                        <label for="Input_SoDienThoai" class="form-label">@Html.DisplayNameFor(model => model.Input.SoDienThoai)</label>
                        <input asp-for="Input.SoDienThoai" class="form-control form-control-lg" />
                        <span asp-validation-for="Input.SoDienThoai" class="text-danger"></span>
                    </div>

                    <div>
                        <label for="Input_Email" class="form-label">@Html.DisplayNameFor(model => model.Input.Email)</label>
                        <input asp-for="Input.Email" class="form-control form-control-lg" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div>
                        <label for="Input_DiaChi" class="form-label">@Html.DisplayNameFor(model => model.Input.DiaChi)</label>
                        <input asp-for="Input.DiaChi" class="form-control form-control-lg" />
                        <span asp-validation-for="Input.DiaChi" class="text-danger"></span>
                    </div>
                </div>
                <div class="account-panel-footer mt-4">
                    <a asp-page="/Account/ChangePassword" class="btn btn-outline-primary">Đổi mật khẩu</a>
                    <button type="submit" class="btn btn-primary">Chỉnh sửa thông tin</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
