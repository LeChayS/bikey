@page
@model bikey.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<section class="account-page py-5">
    <div class="container">
        <div class="account-panel">
            <div class="account-panel__header">
                <h1>Đổi mật khẩu</h1>
                <p>Cập nhật mật khẩu mới để tăng bảo mật cho tài khoản của bạn.</p>
            </div>

            <form method="post" class="account-form mt-4">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="account-form-grid">
                    <div>
                        <label for="Input_CurrentPassword" class="form-label">@Html.DisplayNameFor(model => model.Input.CurrentPassword)</label>
                        <input asp-for="Input.CurrentPassword" class="form-control form-control-lg" />
                        <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
                    </div>

                    <div>
                        <label for="Input_NewPassword" class="form-label">@Html.DisplayNameFor(model => model.Input.NewPassword)</label>
                        <input asp-for="Input.NewPassword" class="form-control form-control-lg" />
                        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                    </div>

                    <div>
                        <label for="Input_ConfirmPassword" class="form-label">@Html.DisplayNameFor(model => model.Input.ConfirmPassword)</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control form-control-lg" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <div class="account-panel-footer mt-4">
                    <a asp-page="/Account/Profile" class="btn btn-outline-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-primary">Cập nhật mật khẩu</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@section Alerts {
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <alert-box type="success" closable="true" title="Thành công">
            @Model.StatusMessage
        </alert-box>
    }
}
