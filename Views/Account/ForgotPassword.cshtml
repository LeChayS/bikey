@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quen Mat Khau";
    Layout = "_AuthLayout";
}

<section class="login-page">
    <div class="container">
        <div class="login-card shadow-lg">
            <div class="login-card__intro">
                <span class="eyebrow">Ho tro tai khoan</span>
                <h1>Quen mat khau</h1>
                <p>
                    Nhap email da dang ky de gui yeu cau ho tro dat lai mat khau.
                </p>
            </div>

            @if (ViewBag.StatusMessage is string statusMessage)
            {
                <div class="alert alert-success mb-3" role="alert">
                    @statusMessage
                </div>
            }

            <form asp-action="ForgotPassword" asp-controller="Account" method="post" class="login-form">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label for="Email" class="form-label">@Html.DisplayNameFor(model => model.Email)</label>
                    <input asp-for="Email" class="form-control form-control-lg" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">Gui yeu cau</button>

                <div class="login-card__actions mt-3">
                    <a asp-action="Login" asp-controller="Account" class="btn btn-outline-secondary">Quay lai dang nhap</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
