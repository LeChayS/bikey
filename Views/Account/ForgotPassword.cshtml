@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_AuthLayout";
}

<section class="login-page">
    <div class="container">
        <div class="login-card shadow-lg">
            <div class="login-card__intro">
                <h1>Quên mật khẩu</h1>
                <p>
                    Vui lòng nhập email đã đăng ký và đặt mật khẩu mới để cập nhật tài khoản trực tiếp trên hệ thống.
                </p>
            </div>

            @if (ViewBag.StatusMessage is string statusMessage)
            {
                <div class="alert alert-success mb-3" role="alert">
                    @statusMessage
                </div>
            }

            <form asp-action="ForgotPassword" asp-controller="Account" method="post" class="login-form">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label for="Email" class="form-label">@Html.DisplayNameFor(model => model.Email)</label>
                    <input asp-for="Email" class="form-control form-control-lg" placeholder="Nhập email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="MatKhauMoi" class="form-label">@Html.DisplayNameFor(model => model.MatKhauMoi)</label>
                    <input asp-for="MatKhauMoi" class="form-control form-control-lg" placeholder="Nhập mật khẩu mới" />
                    <span asp-validation-for="MatKhauMoi" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label for="XacNhanMatKhauMoi" class="form-label">@Html.DisplayNameFor(model => model.XacNhanMatKhauMoi)</label>
                    <input asp-for="XacNhanMatKhauMoi" class="form-control form-control-lg" placeholder="Nhập lại mật khẩu mới" />
                    <span asp-validation-for="XacNhanMatKhauMoi" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">Xác nhận</button>

                <div class="login-card__actions mt-3">
                    <a asp-action="Login" asp-controller="Account" class="btn btn-outline-secondary">Đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
