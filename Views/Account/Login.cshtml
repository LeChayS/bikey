@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_AuthLayout";
}

<section class="login-page">
    <div class="container">
        <div class="login-card shadow-lg">
            <div class="login-card__intro">
                <span class="eyebrow">Tai khoan khach hang</span>
                <h1>Dang nhap de quan ly thong tin thue xe</h1>
                <p>
                    Dang nhap bang email de quan ly thong tin ca nhan, lich su don hang va cac yeu cau dat xe cua ban.
                </p>
            </div>

            <form asp-action="Login" asp-controller="Account" method="post" class="login-form">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label for="Email" class="form-label">@Html.DisplayNameFor(model => model.Email)</label>
                    <input asp-for="Email" class="form-control form-control-lg" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label for="MatKhau" class="form-label">@Html.DisplayNameFor(model => model.MatKhau)</label>
                    <input asp-for="MatKhau" class="form-control form-control-lg" placeholder="Nhap mat khau" />
                    <span asp-validation-for="MatKhau" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">Dang nhap</button>

                <div class="login-card__actions mt-3">
                    <a asp-action="Register" asp-controller="Account" class="btn btn-outline-primary">Dang ky</a>
                    <a asp-action="ForgotPassword" asp-controller="Account" class="btn btn-outline-secondary">Quen mat khau</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
