@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_AuthLayout";
}

<section class="login-page">
    <div class="container">
        <div class="login-card shadow-lg">
            <div class="login-card__intro">
                <h1>Đăng nhập</h1>
                <p>
                    Vui lòng nhập Email và mật khẩu của bạn để đăng nhập
                </p>
            </div>

            <form asp-action="Login" asp-controller="Account" method="post" class="login-form">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label for="Email" class="form-label">@Html.DisplayNameFor(model => model.Email)</label>
                    <input asp-for="Email" class="form-control form-control-lg" placeholder="Nhập email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label for="MatKhau" class="form-label">@Html.DisplayNameFor(model => model.MatKhau)</label>
                    <input asp-for="MatKhau" class="form-control form-control-lg" placeholder="Nhập mật khẩu" />
                    <span asp-validation-for="MatKhau" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">Đăng nhập</button>

                <div class="login-card__actions mt-3">
                    <a asp-action="Register" asp-controller="Account" class="btn btn-outline-primary">Đăng ký</a>
                    <a asp-action="ForgotPassword" asp-controller="Account" class="btn btn-outline-secondary">Quên mật khẩu</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
