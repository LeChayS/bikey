                        <td>Mô tả</td>
                        <td>
                            <em class="text-muted">Không có</em>
                        </td>
                        <td>
                            <span class="badge bg-secondary">
                                <i class="bi bi-eye-slash"></i> Ẩn
                            </span>
                        </td>
                        <td>12/12/1212</td>
                        <td width="180">Thao tác</td>
                    </tr>
                </tbody>
            </table>

            <div class="text-center py-5">
                <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
