@model IEnumerable<bikey.Models.Banner>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý banner";
}

@section Styles {
    <link href="/css/banner/index.css" rel="stylesheet" asp-append-version="true">
}

<!-- Top Header -->
<div class="top-header">
    <h1 class="mb-0"><i class="bi bi-images"></i> Quản Lý Banner</h1>
    <div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm Banner Mới
        </a>
    </div>
</div>


<div class="wrapper">

