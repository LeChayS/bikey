            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>1</th>
                        <th>Hình ảnh</th>
                        <th>Tiêu đề</th>
                        <th>Mô tả</th>
                        <th>Link liên kết</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th width="180">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Thứ tự</td>
                        <td>Hình ảnh</td>
                        <td>Tiêu đề</td>
                        <td>Mô tả</td>
                        <td>
