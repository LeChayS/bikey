@model DatXeViewModel

@{
    ViewData["Title"] = "Dat Xe";
}

<section class="account-page py-5">
    <div class="container">
        <div class="account-panel">
            <div class="account-panel__header">
                <span class="eyebrow">Thong tin dat xe</span>
                <h1>Xac nhan thong tin dat xe</h1>
                <p>Vui long kiem tra thong tin xe va dien day du thong tin ca nhan truoc khi gui yeu cau den admin panel.</p>
            </div>

            <form asp-action="Create" method="post" class="account-form mt-4" id="bookingForm">
                @Html.AntiForgeryToken()
                <input asp-for="MaXe" type="hidden" />
                <input asp-for="GiaThueNgay" type="hidden" />
                <input asp-for="TenXe" type="hidden" />
                <input asp-for="BienSoXe" type="hidden" />
                <input asp-for="HangXe" type="hidden" />
                <input asp-for="DongXe" type="hidden" />
                <input asp-for="TrangThaiXe" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="booking-summary-card">
                    <h2>Thong tin xe</h2>
                    <div class="booking-summary-grid">
                        <div class="profile-item">
                            <span>Ten xe</span>
                            <strong>@Model.TenXe</strong>
                        </div>
                        <div class="profile-item">
                            <span>Bien so</span>
                            <strong>@Model.BienSoXe</strong>
                        </div>
                        <div class="profile-item">
                            <span>Hang xe</span>
                            <strong>@Model.HangXe</strong>
                        </div>
                        <div class="profile-item">
                            <span>Dong xe</span>
                            <strong>@Model.DongXe</strong>
                        </div>
                        <div class="profile-item">
                            <span>Trang thai</span>
                            <strong>@Model.TrangThaiXe</strong>
                        </div>
                        <div class="profile-item">
                            <span>Gia thue/ngay</span>
                            <strong id="giaThueDisplay">@Model.GiaThueNgay.ToString("N0") VND</strong>
                        </div>
                    </div>
                </div>

                <div class="account-form-grid mt-4">
                    <div>
                        <label for="HoTenKhachHang" class="form-label">@Html.DisplayNameFor(model => model.HoTenKhachHang)</label>
                        <input asp-for="HoTenKhachHang" class="form-control form-control-lg" />
                        <span asp-validation-for="HoTenKhachHang" class="text-danger"></span>
                    </div>

                    <div>
                        <label for="SoDienThoai" class="form-label">@Html.DisplayNameFor(model => model.SoDienThoai)</label>
                        <input asp-for="SoDienThoai" class="form-control form-control-lg" />
                        <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                    </div>

                    <div>
                        <label for="DiaChi" class="form-label">@Html.DisplayNameFor(model => model.DiaChi)</label>
                        <input asp-for="DiaChi" class="form-control form-control-lg" />
                        <span asp-validation-for="DiaChi" class="text-danger"></span>
                    </div>

                    <div>
                        <label for="CanCuoc" class="form-label">@Html.DisplayNameFor(model => model.CanCuoc)</label>
                        <input asp-for="CanCuoc" class="form-control form-control-lg" />
                        <span asp-validation-for="CanCuoc" class="text-danger"></span>
                    </div>

                    <div>
                        <label for="NgayNhanDuKien" class="form-label">@Html.DisplayNameFor(model => model.NgayNhanDuKien)</label>
                        <input asp-for="NgayNhanDuKien" class="form-control form-control-lg booking-date-input" />
                        <span asp-validation-for="NgayNhanDuKien" class="text-danger"></span>
                    </div>

                    <div>
                        <label for="NgayTraDuKien" class="form-label">@Html.DisplayNameFor(model => model.NgayTraDuKien)</label>
                        <input asp-for="NgayTraDuKien" class="form-control form-control-lg booking-date-input" />
                        <span asp-validation-for="NgayTraDuKien" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3">
                    <label for="GhiChu" class="form-label">@Html.DisplayNameFor(model => model.GhiChu)</label>
                    <textarea asp-for="GhiChu" class="form-control booking-note-input" rows="4" placeholder="Them yeu cau giao xe, gio nhan xe hoac ghi chu khac neu can"></textarea>
                    <span asp-validation-for="GhiChu" class="text-danger"></span>
                </div>

                <div class="booking-total-card mt-4">
                    <span>Tong tien du kien</span>
                    <strong id="tongTienDisplay">@Model.TongTienDuKien.ToString("N0") VND</strong>
                </div>

                <div class="account-panel-footer mt-4">
                    <a asp-controller="TrangChu" asp-action="DanhSachXe" class="btn btn-outline-secondary">Quay lai</a>
                    <button type="submit" class="btn btn-primary">Xac nhan</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const ngayNhanInput = document.getElementById("NgayNhanDuKien");
            const ngayTraInput = document.getElementById("NgayTraDuKien");
            const giaThue = Number(document.getElementById("GiaThueNgay").value || 0);
            const tongTienDisplay = document.getElementById("tongTienDisplay");

            const updateTongTien = () => {
                const ngayNhan = new Date(ngayNhanInput.value);
                const ngayTra = new Date(ngayTraInput.value);

                if (Number.isNaN(ngayNhan.getTime()) || Number.isNaN(ngayTra.getTime())) {
                    tongTienDisplay.textContent = "0 VND";
                    return;
                }

                const millisecondsPerDay = 24 * 60 * 60 * 1000;
                const soNgay = Math.max(0, Math.round((ngayTra - ngayNhan) / millisecondsPerDay));
                const tongTien = soNgay * giaThue;
                tongTienDisplay.textContent = `${tongTien.toLocaleString("vi-VN")} VND`;
            };

            ngayNhanInput?.addEventListener("change", updateTongTien);
            ngayTraInput?.addEventListener("change", updateTongTien);
            updateTongTien();
        })();
    </script>
}
