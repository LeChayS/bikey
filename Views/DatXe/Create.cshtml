@model DatXeViewModel

@{
    ViewData["Title"] = "Dat Xe";
}

<section class="booking-confirm-page">
    <div class="container">
        <div class="booking-confirm-shell">
            <header class="booking-confirm-hero">
                <div class="booking-confirm-hero__icon" aria-hidden="true">
                    <i class="bi bi-clipboard-check"></i>
                </div>
                <h1>Xác nhận đặt chỗ</h1>
                <p>Hoàn tất thông tin để gửi yêu cầu đặt xe</p>
            </header>

            <div class="booking-confirm-body">
                <form asp-controller="DatXe" asp-action="Create" method="post" class="account-form" id="bookingForm">
                    @Html.AntiForgeryToken()
                    <input asp-for="MaXe" type="hidden" />
                    <input asp-for="GiaThueNgay" type="hidden" />
                    <input asp-for="TenXe" type="hidden" />
                    <input asp-for="BienSoXe" type="hidden" />
                    <input asp-for="HangXe" type="hidden" />
                    <input asp-for="DongXe" type="hidden" />
                    <input asp-for="TrangThaiXe" type="hidden" />

                    <div class="booking-confirm-layout">
                        <div class="booking-confirm-main">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                            <section class="booking-section" aria-labelledby="booking-customer-heading">
                                <h2 class="booking-section__title" id="booking-customer-heading">
                                    <i class="bi bi-person-vcard" aria-hidden="true"></i>
                                    Thông tin khách hàng
                                </h2>
                                <div class="booking-confirm-form-grid">
                                    <div class="booking-field">
                                        <label asp-for="HoTenKhachHang" class="form-label"></label>
                                        <input asp-for="HoTenKhachHang" class="form-control form-control-lg" />
                                        <span asp-validation-for="HoTenKhachHang" class="text-danger"></span>
                                    </div>
                                    <div class="booking-field">
                                        <label asp-for="SoDienThoai" class="form-label"></label>
                                        <input asp-for="SoDienThoai" class="form-control form-control-lg" />
                                        <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                                    </div>
                                    <div class="booking-field">
                                        <label asp-for="CanCuoc" class="form-label"></label>
                                        <input asp-for="CanCuoc" class="form-control form-control-lg" inputmode="numeric" autocomplete="off" />
                                        <span asp-validation-for="CanCuoc" class="text-danger"></span>
                                    </div>
                                    <div class="booking-field">
                                        <label asp-for="Email" class="form-label"></label>
                                        <input asp-for="Email" class="form-control form-control-lg" type="email" autocomplete="email" />
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                    <div class="booking-field booking-field--full">
                                        <label asp-for="DiaChi" class="form-label"></label>
                                        <input asp-for="DiaChi" class="form-control form-control-lg" />
                                        <span asp-validation-for="DiaChi" class="text-danger"></span>
                                    </div>
                                </div>
                            </section>

                            <section class="booking-section" aria-labelledby="booking-order-heading">
                                <h2 class="booking-section__title" id="booking-order-heading">
                                    <i class="bi bi-list-ul" aria-hidden="true"></i>
                                    Thông tin xe thuê
                                </h2>
                                <div class="booking-vehicle-detail-stack">
                                    <div class="booking-vehicle-detail-card booking-vehicle-detail-card--media">
                                        <div class="booking-vehicle-detail-media" aria-hidden="true">
                                            <i class="bi bi-scooter"></i>
                                        </div>
                                    </div>

                                    <div class="booking-vehicle-detail-card">
                                        <div class="booking-vehicle-detail-card__header">
                                            <span class="booking-vehicle-detail-card__icon booking-vehicle-detail-card__icon--info" aria-hidden="true"><i class="bi bi-info-circle"></i></span>
                                            <h3 class="booking-vehicle-detail-card__title">Thông tin cơ bản</h3>
                                        </div>
                                        <div class="booking-vehicle-detail-kv-grid">
                                            <div class="booking-vehicle-detail-kv">
                                                <span class="booking-vehicle-detail-kv__label">Mã xe</span>
                                                <span class="booking-vehicle-detail-kv__value">#XE@Model.MaXe.ToString("D3")</span>
                                            </div>
                                            <div class="booking-vehicle-detail-kv">
                                                <span class="booking-vehicle-detail-kv__label">Tên xe</span>
                                                <span class="booking-vehicle-detail-kv__value">@Model.TenXe</span>
                                            </div>
                                            <div class="booking-vehicle-detail-kv">
                                                <span class="booking-vehicle-detail-kv__label">Biển số</span>
                                                <span class="booking-vehicle-detail-kv__value">@Model.BienSoXe</span>
                                            </div>
                                            <div class="booking-vehicle-detail-kv">
                                                <span class="booking-vehicle-detail-kv__label">Hãng xe</span>
                                                <span class="booking-vehicle-detail-kv__value">@Model.HangXe</span>
                                            </div>
                                            <div class="booking-vehicle-detail-kv">
                                                <span class="booking-vehicle-detail-kv__label">Dòng xe</span>
                                                <span class="booking-vehicle-detail-kv__value">@Model.DongXe</span>
                                            </div>
                                            <div class="booking-vehicle-detail-kv">
                                                <span class="booking-vehicle-detail-kv__label">Loại xe</span>
                                                <span class="booking-vehicle-detail-kv__value">@Model.TenLoaiXe</span>
                                            </div>
                                            <div class="booking-vehicle-detail-kv">
                                                <span class="booking-vehicle-detail-kv__label">Giá thuê/ngày</span>
                                                <span class="booking-vehicle-detail-kv__value" id="giaThueDisplay">@Model.GiaThueNgay.ToString("N0") VNĐ</span>
                                            </div>
                                            <div class="booking-vehicle-detail-kv">
                                                <span class="booking-vehicle-detail-kv__label">Giá trị xe</span>
                                                <span class="booking-vehicle-detail-kv__value">@Model.GiaTriXe.ToString("N0") VNĐ</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <section class="booking-section" aria-labelledby="booking-order-detail-heading">
                                <h2 class="booking-section__title" id="booking-order-detail-heading">
                                    <i class="bi bi-journal-text" aria-hidden="true"></i>
                                    Thông tin đơn
                                </h2>
                                <div class="booking-vehicle-detail-card booking-vehicle-detail-card--plain">
                                    <div class="booking-vehicle-detail-date-grid">
                                        <div class="booking-date-wrap">
                                            <label asp-for="NgayNhanDuKien" class="form-label booking-date-label"></label>
                                            <input asp-for="NgayNhanDuKien" class="form-control form-control-lg booking-date-input" />
                                            <span asp-validation-for="NgayNhanDuKien" class="text-danger d-block small"></span>
                                        </div>
                                        <div class="booking-date-wrap">
                                            <label asp-for="NgayTraDuKien" class="form-label booking-date-label"></label>
                                            <input asp-for="NgayTraDuKien" class="form-control form-control-lg booking-date-input" />
                                            <span asp-validation-for="NgayTraDuKien" class="text-danger d-block small"></span>
                                        </div>
                                    </div>
                                    <p class="booking-vehicle-detail-range" id="bookingDateRangeText" aria-live="polite"></p>
                                    <div class="booking-order-note mt-3">
                                        <label asp-for="GhiChu" class="form-label"></label>
                                        <textarea asp-for="GhiChu" class="form-control booking-note-input" rows="4" placeholder="Thêm yêu cầu giao xe, giờ nhận xe hoặc ghi chú khác nếu cần"></textarea>
                                        <span asp-validation-for="GhiChu" class="text-danger"></span>
                                    </div>
                                </div>
                            </section>
                        </div>

                        <aside class="booking-confirm-aside">
                            <div class="booking-summary-panel">
                                <h3 class="booking-summary-panel__title">
                                    <i class="bi bi-receipt" aria-hidden="true"></i>
                                    Tóm tắt đơn hàng
                                </h3>
                                <div class="booking-summary-rows">
                                    <div class="booking-summary-row">
                                        <span>Thời gian thuê</span>
                                        <span id="bookingSoNgaySummary">—</span>
                                    </div>
                                    <div class="booking-summary-row">
                                        <span>Giá thuê/ngày</span>
                                        <span id="bookingGiaNgaySidebar">@Model.GiaThueNgay.ToString("N0") đ</span>
                                    </div>
                                </div>
                                <div class="booking-summary-total">
                                    <span>Tổng cộng</span>
                                    <strong id="tongTienDisplay">@Model.TongTienDuKien.ToString("N0") VNĐ</strong>
                                </div>
                                <div class="booking-summary-actions">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-check2-circle" aria-hidden="true"></i>
                                        Xác nhận đặt chỗ
                                    </button>
                                    <a asp-controller="TrangChu" asp-action="DanhSachXe" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left" aria-hidden="true"></i>
                                        Quay lại danh sách xe
                                    </a>
                                </div>
                                <p class="booking-summary-footnote">
                                    Giá hiển thị là tạm tính theo số ngày và giá ngày hiện tại; nhân viên sẽ xác nhận lại trước khi duyệt đơn.
                                </p>
                            </div>
                        </aside>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const ngayNhanInput = document.getElementById("NgayNhanDuKien");
            const ngayTraInput = document.getElementById("NgayTraDuKien");
            const giaThue = Number(document.getElementById("GiaThueNgay").value || 0);
            const tongTienDisplay = document.getElementById("tongTienDisplay");
            const bookingDateRangeText = document.getElementById("bookingDateRangeText");
            const bookingSoNgaySummary = document.getElementById("bookingSoNgaySummary");
            const giaThueDisplay = document.getElementById("giaThueDisplay");
            const bookingGiaNgaySidebar = document.getElementById("bookingGiaNgaySidebar");

            const formatMoneyVndLabel = (n) => `${n.toLocaleString("vi-VN")} VNĐ`;

            const updateTongTien = () => {
                const ngayNhan = new Date(ngayNhanInput.value);
                const ngayTra = new Date(ngayTraInput.value);

                if (Number.isNaN(ngayNhan.getTime()) || Number.isNaN(ngayTra.getTime())) {
                    tongTienDisplay.textContent = "0 VNĐ";
                    if (bookingDateRangeText) bookingDateRangeText.innerHTML = '<i class="bi bi-calendar3" aria-hidden="true"></i> Chọn ngày nhận và ngày trả';
                    if (bookingSoNgaySummary) bookingSoNgaySummary.textContent = "—";
                    return;
                }

                const millisecondsPerDay = 24 * 60 * 60 * 1000;
                const soNgay = Math.max(0, Math.round((ngayTra - ngayNhan) / millisecondsPerDay));
                const tongTien = soNgay * giaThue;
                const tongStr = formatMoneyVndLabel(tongTien);

                tongTienDisplay.textContent = tongStr;

                if (bookingDateRangeText) {
                    const a = ngayNhan.toLocaleDateString("vi-VN");
                    const b = ngayTra.toLocaleDateString("vi-VN");
                    bookingDateRangeText.innerHTML =
                        soNgay > 0
                            ? `<i class="bi bi-calendar3" aria-hidden="true"></i> ${a} - ${b} (${soNgay} ngày)`
                            : `<i class="bi bi-calendar3" aria-hidden="true"></i> ${a} - ${b}`;
                }

                if (bookingSoNgaySummary) {
                    bookingSoNgaySummary.textContent = soNgay > 0 ? `${soNgay} ngày` : "—";
                }
            };

            if (giaThueDisplay) {
                giaThueDisplay.textContent = `${giaThue.toLocaleString("vi-VN")} VNĐ`;
            }
            if (bookingGiaNgaySidebar) {
                bookingGiaNgaySidebar.textContent = `${giaThue.toLocaleString("vi-VN")} đ`;
            }

            ngayNhanInput?.addEventListener("change", updateTongTien);
            ngayTraInput?.addEventListener("change", updateTongTien);
            ngayNhanInput?.addEventListener("input", updateTongTien);
            ngayTraInput?.addEventListener("input", updateTongTien);
            updateTongTien();
        })();
    </script>
}
