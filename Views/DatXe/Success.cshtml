@model DatCho

@{
    ViewData["Title"] = "Dat Xe Thanh Cong";
}

<section class="account-page py-5">
    <div class="container">
        <div class="account-panel">
            <div class="account-panel__header">
                <h1>Đặt xe thành công</h1>
                <p>@TempData["BookingSuccessMessage"]</p>
            </div>

            <div class="booking-summary-grid mt-4">
                <div class="profile-item">
                    <span>Mã đơn đặt xe</span>
                    <strong>#@Model.MaDatCho</strong>
                </div>
                <div class="profile-item">
                    <span>Trạng thái</span>
                    <strong>@Model.TrangThai</strong>
                </div>
                <div class="profile-item">
                    <span>Tên xe</span>
                    <strong>@Model.Xe?.TenXe</strong>
                </div>
                <div class="profile-item">
                    <span>Khách hàng</span>
                    <strong>@Model.HoTen</strong>
                </div>
                <div class="profile-item">
                    <span>Thời gian dự kiến</span>
                    <strong>@Model.NgayNhanXe.ToString("dd/MM/yyyy") - @Model.NgayTraXe.ToString("dd/MM/yyyy")</strong>
                </div>
                <div class="profile-item">
                    <span>Tổng tiền dự kiến</span>
                    <strong>@Model.TongTienDuKien.ToString("N0") VNĐ</strong>
                </div>
            </div>

            <div class="account-panel-footer mt-4">
                <a asp-page="/Account/Orders" class="btn btn-outline-primary">Xem lịch sử đơn hàng</a>
                <a asp-controller="TrangChu" asp-action="DanhSachXe" class="btn btn-primary">Tiếp tục đặt xe</a>
            </div>
        </div>
    </div>
</section>
