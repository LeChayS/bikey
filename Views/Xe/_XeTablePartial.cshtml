@model IEnumerable<bikey.Models.Xe>

<table class="table table-hover mb-0">
    <thead class="table-primary">
        <tr>
            <th>Mã xe</th>
            <th>Hình ảnh</th>
            <th>Tên xe</th>
            <th>Loại xe</th>
            <th>Biển số</th>
            <th>Giá thuê/ngày</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var xe in Model)
            {
                var status = xe.TrangThai;
                var badgeClass = status switch
                {
                    "Sẵn sàng" => "bg-success",
                    "Đang thuê" => "bg-warning text-dark",
                    "Bảo trì" => "bg-danger",
                    "Đã xóa" => "bg-dark",
                    _ => "bg-secondary"
                };
                var deletedClass = status == "Đã xóa" ? "vehicle-deleted" : "";

                var tenFile = xe.HinhAnhHienThi;
                string? imgSrc = null;
                if (!string.IsNullOrEmpty(tenFile))
                {
                    if (tenFile.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
                        tenFile.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
                        tenFile.StartsWith("/"))
                    {
                        imgSrc = tenFile;
                    }
                    else if (tenFile.StartsWith("images/", StringComparison.OrdinalIgnoreCase))
                    {
                        imgSrc = "/" + tenFile;
                    }
                    else
                    {
                        imgSrc = "/images/xe/" + tenFile;
                    }
                }

                <tr class="@deletedClass">
                    <td>#XE@(xe.MaXe.ToString("D3"))</td>
                    <td>
                        @if (!string.IsNullOrEmpty(imgSrc))
                        {
                            <img src="@imgSrc" style="width:50px;height:50px;object-fit:cover;" />
                        }
                        else
                        {
                            <i class="bi bi-image" style="font-size:30px;color:#ccc;"></i>
                        }
                    </td>
                    <td>
                        <strong>@xe.TenXe</strong>
                        @if (status == "Đang thuê")
                        {
                            <span class="position-relative">
                                <span class="rental-indicator"></span>
                            </span>
                        }
                    </td>
                    <td>@xe.LoaiXe?.TenLoaiXe</td>
                    <td>@xe.BienSoXe</td>
                    <td class="text-danger"><strong>@xe.GiaThue.ToString("N0")đ</strong></td>
                    <td>
                        <span class="badge @badgeClass">@xe.TrangThai</span>
                    </td>
                    <td>
                        <button type="button" class="btn btn-info btn-sm" onclick="showXeDetails(@xe.MaXe)" title="Xem chi tiết">
                            <i class="bi bi-eye"></i>
                        </button>

                        @if (xe.TrangThai == "Đang thuê")
                        {
                            <span class="btn-wrapper">
                                <button class="btn btn-warning btn-sm btn-disabled" disabled>
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <span class="custom-tooltip">Không thể sửa xe đang cho thuê</span>
                            </span>
                            <span class="btn-wrapper">
                                <button class="btn btn-danger btn-sm btn-disabled" disabled>
                                    <i class="bi bi-trash"></i>
                                </button>
                                <span class="custom-tooltip">Không thể xóa xe đang cho thuê</span>
                            </span>
                        }
                        else
                        {
                            <a asp-action="Edit" asp-route-id="@xe.MaXe" class="btn btn-warning btn-sm" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button"
                                    class="btn btn-danger btn-sm delete-xe-btn"
                                    title="Xóa"
                                    data-id="@xe.MaXe"
                                    data-ma-xe="#XE@(xe.MaXe.ToString("D3"))"
                                    data-ten-xe="@xe.TenXe"
                                    data-bien-so="@xe.BienSoXe"
                                    data-hang-xe="@xe.HangXe"
                                    data-dong-xe="@xe.DongXe"
                                    data-loai-xe="@xe.LoaiXe?.TenLoaiXe"
                                    data-gia-thue="@xe.GiaThue.ToString("N0")đ/ngày"
                                    data-trang-thai="@xe.TrangThai">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-center text-muted py-4">
                    <i class="bi bi-search" style="font-size:2rem;"></i>
                    <br />
                    Không tìm thấy xe nào phù hợp với bộ lọc
                </td>
            </tr>
        }
    </tbody>
</table>