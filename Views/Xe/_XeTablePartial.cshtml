@model IEnumerable<bikey.Models.Xe>

<table class="table table-hover mb-0">
    <thead class="table-primary">
        <tr>
            <th>Mã xe</th>
            <th>Hình ảnh</th>
            <th>Tên xe</th>
            <th>Loại xe</th>
            <th>Biển số</th>
            <th>Giá thuê/ngày</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @* @if (Model.Any())
        {
            @foreach (var xe in Model)
            {
                <tr class="@(xe.TrangThai == "Đã xóa" ? "vehicle-deleted" : "")">
                    <td>#XE@(xe.MaXe.ToString("D3"))</td>
                    <td>
                        @if (!string.IsNullOrEmpty(xe.HinhAnhHienThi))
                        {
                            <img src="~/images/xe/@xe.HinhAnhHienThi" style="width:50px;height:50px;object-fit:cover;" />
                        }
                        else
                        {
                            <i class="bi bi-image" style="font-size:30px;color:#ccc;"></i>
                        }
                    </td>
                    <td>
                        <strong>@xe.TenXe</strong>
                        @if (xe.TrangThai == "Đang thuê")
                        {
                            <span class="position-relative">
                                <span class="rental-indicator"></span>
                            </span>
                        }
                    </td>
                    <td>@xe.LoaiXe?.TenLoaiXe</td>
                    <td>@xe.BienSoXe</td>
                    <td class="text-danger"><strong>@xe.GiaThue.ToString("N0")đ</strong></td>
                    <td>
                        @{
                            string badgeClass = xe.TrangThai switch
                            {
                                                "Sẵn sàng" => "bg-success",
                                                "Đang thuê" => "bg-warning text-dark",
                                                "Bảo trì" => "bg-danger",
                                                "Đã xóa" => "bg-dark",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@xe.TrangThai</span>
                    </td>
                    <td>
                        <!-- View Details button (always available) -->
                        <button type="button" class="btn btn-info btn-sm" onclick="showXeDetails(@xe.MaXe)" title="Xem chi tiết">
                            <i class="bi bi-eye"></i>
                        </button>

                        @if (xe.TrangThai == "Đang thuê")
                        {
                            <!-- Edit button disabled -->
                            <span class="btn-wrapper">
                                <button class="btn btn-warning btn-sm btn-disabled" disabled>
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <span class="custom-tooltip">Không thể sửa xe đang cho thuê</span>
                            </span>
                            <!-- Delete button disabled -->
                            <span class="btn-wrapper">
                                <button class="btn btn-danger btn-sm btn-disabled" disabled>
                                    <i class="bi bi-trash"></i>
                                </button>
                                <span class="custom-tooltip">Không thể xóa xe đang cho thuê</span>
                            </span>
                        }
                        else if (xe.TrangThai == "Đã xóa")
                        {
                            <!-- Restore button for deleted vehicles -->
                            <form asp-action="Restore" method="post" style="display: inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@xe.MaXe" />
                                <button type="submit" class="btn btn-success btn-sm" title="Khôi phục xe">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                            </form>
                        }
                        else
                        {
                            <!-- Normal Edit/Delete buttons -->
                            <a asp-action="Edit" asp-route-id="@xe.MaXe" class="btn btn-warning btn-sm" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@xe.MaXe" class="btn btn-danger btn-sm" title="Xóa">
                                <i class="bi bi-trash"></i>
                            </a>
                        }
                    </td>
                </tr>
            }
        }
        else
        { *@
            <tr>
                <td>Mã xe</td>
                <td>Hình ảnh</td>
                <td>Tên xe</td>
                <td>Loại xe</td>
                <td>Biển số</td>
                <td>Giá thuê/ngày</td>
                <td>Trạng thái</td>
                <td>
                    <button type="button" class="btn btn-info btn-sm" title="Xem chi tiết">
                        <i class="bi bi-eye"></i>
                    </button>
                    <a asp-action="Edit" class="btn btn-warning btn-sm" title="Sửa">
                        <i class="bi bi-pencil"></i>
                    </a>
                <a class="btn btn-danger btn-sm" title="Xóa" data-bs-toggle="modal" data-bs-target="#deleteXe">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
            <tr>
                <td colspan="9" class="text-center text-muted py-4">
                    <i class="bi bi-search" style="font-size:2rem;"></i>
                    <br>
                    Không tìm thấy xe nào phù hợp với bộ lọc
                </td>
            </tr>
        @* } *@
    </tbody>
</table>