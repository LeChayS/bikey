@model bikey.ViewModels.XeIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý xe";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/stat-card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/xe/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shared/admin-filter-bar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shared/responsive.css" asp-append-version="true" />
    <link href="~/css/components/alert-box.css" rel="stylesheet" asp-append-version="true">
}

@section Scripts {
    <script src="/js/xe/index.js" asp-append-version="true"></script>
}

<div class="top-header">
    <h1><i class="bi bi-scooter"></i> Quản Lý Xe</h1>
    <div>
        <a asp-action="Create" class="btn btn-add">
            <i class="bi bi-plus-circle"></i> Thêm Xe Mới
        </a>
        <a asp-page="/Xe/DaXoa/Index" class="btn btn-outline-secondary">
            <i class="bi bi-trash2"></i> Xem xe đã xóa
        </a>
    </div>
</div>

<div class="wrapper">
    <!-- Statistics -->
    <div class="container-fluid">
        <div class="row">
            @* card 1 *@
            <div class="col-lg-3 col-md-6">
                <stat-card label="Tổng số xe"
                           value="@Model.TongSoXe"
                           tone="blue"
                           align="center" />
            </div>
            @* card 2 *@
            <div class="col-lg-3 col-md-6">
                <stat-card label="Xe sẵn sàng"
                           value="@Model.XeSanSang"
                           tone="red"
                           align="center" />
            </div>
            @* card 3 *@
            <div class="col-lg-3 col-md-6">
                <stat-card label="Đang cho thuê"
                           value="@Model.DangChoThue"
                           tone="purple"
                           align="center" />
            </div>
            @* card 4 *@
            <div class="col-lg-3 col-md-6">
                <stat-card label="Bảo trì"
                           value="@Model.BaoTri"
                           tone="green"
                           align="center" />
            </div>
        </div>
    </div>

    <!-- table & filter -->
    <div class="container-fluid">
        @* filter *@
        <div class="filter-section">
            <div class="row g-3 align-items-end filter-bar">
                <div class="col filter-bar-field">
                    <label class="form-label">Tìm kiếm</label>
                    <input id="searchString" class="form-control" placeholder="Tên xe hoặc biển số" />
                </div>
                <div class="col filter-bar-field">
                    <label class="form-label">Loại xe</label>
                    <select id="loaiXe" class="form-select">
                        <option value="">Loại xe</option>
                        @foreach (var item in Model.LoaiXeList)
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                </div>
                <div class="col filter-bar-field">
                    <label class="form-label">Hãng xe</label>
                    <select id="hangXe" class="form-select">
                        <option value="">Hãng xe</option>
                        @foreach (var item in Model.HangXeList)
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                </div>
                <div class="col filter-bar-field">
                    <label class="form-label">Trạng thái</label>
                    <select id="trangThai" class="form-select">
                        <option value="">Trạng thái xe</option>
                        @foreach (var item in Model.TrangThaiList)
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                </div>
                <div class="col-auto filter-bar-action">
                    <label class="form-label d-block">&nbsp;</label>
                    <button type="button" id="clearFilterBtn" class="btn btn-secondary">
                        <i class="bi bi-arrow-clockwise"></i> Làm mới
                    </button>
                </div>
            </div>
        </div>

        <!-- table -->
        <div class="card-body" id="xeTableContainer">
            <partial name="_XeTablePartial" model="new XeTablePartialModel { Items = Model.XeList, Variant = XeTableVariant.QuanLy }" />
        </div>
    </div>
</div>


@* modal xóa xe *@
<div class="modal fade" id="deleteXe" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-circle"></i> Xóa xe</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <h5>Bạn có chắc chắn muốn xóa xe này?</h5>
                <small class="text-muted">Xe bị xóa sẽ được chuyển sang trạng thái “Đã xóa” và có thể khôi phục từ trang “Xe đã xóa”.</small>
                <div class="vehicle-info">
                    <h5 class="mb-3">
                        Thông Tin Xe
                        <span class="history-indicator float-end" id="deleteXeHistoryBadge" style="display:none;">
                            <i class="bi bi-clock-history"></i> Có lịch sử thuê
                        </span>
                    </h5>

                    <div class="info-item">
                        <span class="info-label">Mã xe:</span>
                        <span class="info-value" id="deleteXeMaXe">-</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Tên xe:</span>
                        <span class="info-value" id="deleteXeTenXe">-</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Biển số:</span>
                        <span class="info-value" id="deleteXeBienSo">-</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Hãng xe:</span>
                        <span class="info-value" id="deleteXeHangXe">-</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Dòng xe:</span>
                        <span class="info-value" id="deleteXeDongXe">-</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Loại xe:</span>
                        <span class="info-value" id="deleteXeLoaiXe">-</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Giá thuê:</span>
                        <span class="info-value text-danger"><strong id="deleteXeGiaThue">-</strong></span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Trạng thái:</span>
                        <span class="info-value" id="deleteXeTrangThai">-</span>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteXeBtn">
                    <i class="bi bi-check-circle"></i> Xóa xe
                </button>
            </div>
        </div>
    </div>
</div>

@* modal xem chi tiết thông tin xe *@
<div class="modal fade" id="detailXe" tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-info-circle"></i> Thông tin xe</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <!-- Image main -->
                <div class="xe-details-image-section mb-3">
                    <div id="xeImageContainer">
                        <div class="xe-details-image-placeholder">
                            <i class="bi bi-image"></i>
                        </div>
                    </div>
                </div>

                <div class="xe-details-info-card mb-3">
                    <h4><i class="bi bi-info-circle"></i> Thông tin cơ bản</h4>
                    <div class="xe-details-info-grid">
                        <div class="xe-details-info-item">
                            <span class="xe-details-info-label">Mã xe</span>
                            <span class="xe-details-info-value" id="xeMaXe">-</span>
                        </div>
                        <div class="xe-details-info-item">
                            <span class="xe-details-info-label">Tên xe</span>
                            <span class="xe-details-info-value" id="xeTenXe">-</span>
                        </div>
                        <div class="xe-details-info-item">
                            <span class="xe-details-info-label">Biển số</span>
                            <span class="xe-details-info-value" id="xeBienSo">-</span>
                        </div>
                        <div class="xe-details-info-item">
                            <span class="xe-details-info-label">Hãng xe</span>
                            <span class="xe-details-info-value" id="xeHangXe">-</span>
                        </div>
                        <div class="xe-details-info-item">
                            <span class="xe-details-info-label">Dòng xe</span>
                            <span class="xe-details-info-value" id="xeDongXe">-</span>
                        </div>
                        <div class="xe-details-info-item">
                            <span class="xe-details-info-label">Loại xe</span>
                            <span class="xe-details-info-value" id="xeLoaiXe">-</span>
                        </div>
                    </div>
                </div>

                <!-- Status -->
                <div class="xe-details-info-card mb-3">
                    <h4><i class="bi bi-flag"></i> Trạng thái</h4>
                    <div id="xeTrangThaiContainer">
                        <!-- Status badge will be loaded here -->
                    </div>
                </div>

                <!-- Financial Info -->
                <div class="xe-details-info-card mb-3">
                    <h4><i class="bi bi-currency-dollar"></i> Thông tin tài chính</h4>
                    <div class="xe-details-info-grid">
                        <div class="xe-details-info-item">
                            <span class="xe-details-info-label">Giá thuê/ngày</span>
                            <span class="xe-details-info-value" id="xeGiaThue">-</span>
                        </div>
                        <div class="xe-details-info-item">
                            <span class="xe-details-info-label">Giá trị xe</span>
                            <span class="xe-details-info-value" id="xeGiaTriXe">-</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>

</div>

@section Alerts {
    @if (TempData["XeManagementSuccess"] is string successMessage)
    {
        <alert-box type="success" closable="true" title="Thành công">
            @successMessage
        </alert-box>
    }
    @if (TempData["XeManagementError"] is string errorMessage)
    {
        <alert-box type="danger" closable="true" title="Lỗi">
            @errorMessage
        </alert-box>
    }
}
