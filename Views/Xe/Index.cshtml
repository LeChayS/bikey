@model IEnumerable<bikey.Models.Xe>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý xe";
}

@section Styles {
    <link rel="stylesheet" href="~/css/xe/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shared/responsive.css" asp-append-version="true" />
}

@section Scripts {
    <script src="/js/xe/index.js"></script>
}

<div class="top-header">
    <h1><i class="bi bi-scooter"></i> Quản Lý Xe</h1>
    <div>
        <a asp-action="Create" class="btn btn-add">
            <i class="bi bi-plus-circle"></i> Thêm Xe Mới
        </a>
        <a asp-action="Index" asp-route-showDeleted="true" class="btn btn-warning">
            <i class="bi bi-trash"></i> Xem xe đã xóa
        </a>
    </div>
</div>

<div class="wrapper">

    <!-- Statistics -->
    <div class="container-fluid">
        <div class="row">
            @* card 1 *@
            <div class="col-lg-3 col-md-6">
                <div class="stat-card blue">
                    <div class="stat-label">Tổng số xe</div>
                    <div class="stat-value">
                        @* @ViewBag.TongSoXe *@
                        2
                    </div>
                </div>
            </div>
            @* card 2 *@
            <div class="col-lg-3 col-md-6">
                <div class="stat-card red">
                    <div class="stat-label">Xe sẵn sàng</div>
                    <div class="stat-value">
                        @* @ViewBag.XeSanSang *@
                        10
                    </div>
                </div>
            </div>
            @* card 3 *@
            <div class="col-lg-3 col-md-6">
                <div class="stat-card purple">
                    <div class="stat-label">Đang cho thuê</div>
                    <div class="stat-value">
                        @* @ViewBag.DangChoThue *@
                        10
                    </div>
                </div>
            </div>
            @* card 4 *@
            <div class="col-lg-3 col-md-6">
                <div class="stat-card green">
                    <div class="stat-label">Bảo trì</div>
                    <div class="stat-value">
                        @* @ViewBag.BaoTri *@
                        16
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- table & filter -->
    <div class="container-fluid">

        @* filter *@
        <div class="filter-section">
            <div class="row g-3 align-items-center">
                <div class="col">
                    <label class="form-label">Loại xe</label>
                    <select id="loaiXe" class="form-select">
                        <option value="">--- Loại xe ---</option>
                        @* @foreach (var item in ViewBag.LoaiXeList as SelectList)
                        {
                            if (item.Value == ViewBag.CurrentLoaiXe?.ToString())
                            {
                                <option value="@item.Value" selected>@item.Text</option>
                            }
                            else
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        } *@
                        <option>xe đạp</option>
                        <option>xe máy</option>
                    </select>
                </div>
                <div class="col">
                    <label class="form-label">Hãng xe</label>
                    <select id="hangXe" class="form-select">
                        <option value="">--- Hãng xe ---</option>
                        @* @foreach (var item in ViewBag.HangXeList as SelectList)
                        {
                            if (item.Value == ViewBag.CurrentHangXe?.ToString())
                            {
                                <option value="@item.Value" selected>@item.Text</option>
                            }
                            else
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        } *@
                        <option>honda</option>
                        <option>vision</option>
                    </select>
                </div>
                <div class="col">
                    <label class="form-label">Trạng thái</label>
                    <select id="trangThai" class="form-select">
                        <option value="">--- Trạng thái xe ---</option>
                        @* @foreach (var item in ViewBag.TrangThaiList as SelectList)
                        {
                            if (item.Value == ViewBag.CurrentTrangThai?.ToString())
                            {
                                <option value="@item.Value" selected>@item.Text</option>
                            }
                            else
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        } *@
                        <option>Sẵn sàng</option>
                        <option>Đang thuê</option>
                        <option>Bảo trì</option>
                        <option>Hư hỏng</option>
                    </select>
                </div>
                <div class="col">
                    <label class="form-label">&nbsp;</label>
                    <button type="button" id="filterBtn" class="btn btn-primary w-100">
                        <i class="bi bi-funnel"></i> Lọc
                    </button>
                </div>
                <div class="col">
                    <label class="form-label">&nbsp;</label>
                    <button type="button" id="clearFilterBtn" class="btn btn-secondary w-100">
                        <i class="bi bi-arrow-clockwise"></i> Làm mới
                    </button>
                </div>
            </div>
        </div>

        <!-- table -->
        <div class="card-body" id="xeTableContainer">
            @Html.Partial("_XeTablePartial", Model)
        </div>
    </div>

</div>

@* modal thêm mới loại xe *@
<div class="modal fade" id="createLoai" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus"></i> Thêm loại xe mới</h5>
                <button type="button" class="btn-close  btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form asp-action="Create" method="post">
                    <label class="form-label" for="createTenLoaiXe">Tên loại xe *</label>
                    <input type="text" id="createTenLoaiXe" name="TenLoaiXe" class="form-input" required />
                    <span id="createTenLoaiXeError" class="validation-error"></span>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-primary" asp-action="submit"><i class="bi bi-check-circle"></i> Thêm mới</button>
            </div>
        </div>
    </div>
</div>

@* modal chỉnh sửa thông tin loại xe *@
<div class="modal fade" id="editLoai" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square"></i> Sửa loại xe</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" />
                    <label class="form-label" for="editTenLoaiXe">Tên loại xe</label>
                    <input type="text" id="editTenLoaiXe" name="TenLoaiXe" class="form-input" required />
                    <span id="editTenLoaiXeError" class="validation-error"></span>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-primary" asp-action="submit"><i class="bi bi-check-circle"></i> Lưu thay
                    đổi</button>
            </div>
        </div>
    </div>
</div>

@* modal xóa tài khoản *@
<div class="modal fade" id="deleteLoai" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-circle"></i> Xóa loại xe</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <h5>Bạn có chắc chắn muốn xóa loại xe này?</h5>
                <small class="text-muted">Loại xe bị xóa sẽ không thể khôi phục lại được</small>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-danger" asp-action="submit"><i class="bi bi-check-circle"></i> Xóa loại xe</button>
            </div>
        </div>
    </div>
</div>