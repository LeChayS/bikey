@model IEnumerable<bikey.Models.Xe>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý xe";
}
@section Styles {
    <link rel="stylesheet" href="~/css/xe/index.css" />
    <link rel="stylesheet" href="~/css/shared/responsive.css" />
    @* <link rel="stylesheet" href="~/css/custom-modal.css" /> *@
    @* <link rel="stylesheet" href="~/css/xe/xe-details-modal.css" /> *@
}

@section Scripts {
    <script src="/js/xe/index.js"></script>
}

<div class="container-fluid">
    <!-- Header -->
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1>Quản Lý Xe</h1>
                <p class="mb-0">Theo dõi và quản lý các xe</p>
            </div>
            <div class="d-flex gap-2">
                @* @if (ViewBag.ShowDeleted == true)
                { *@
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-eye"></i> Xem xe hoạt động
                    </a>
                @* }
                else
                { *@
                    <a asp-action="Index" asp-route-showDeleted="true" class="btn btn-outline-warning">
                        <i class="bi bi-trash"></i> Xem xe đã xóa
                    </a>
                @* } *@
                <a asp-action="Create" class="btn btn-add">
                    <i class="bi bi-plus-circle"></i> Thêm Xe Mới
                </a>
            </div>
        </div>
    </div>
    

    <!-- Thống kê -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-number">20 @ViewBag.TongSoXe</div>
                <div>Tổng số xe</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-number">12 @ViewBag.XeSanSang</div>
                <div>Xe sẵn sàng</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-number">10 @ViewBag.DangChoThue</div>
                <div>Đang cho thuê</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-number">2 @ViewBag.BaoTri</div>
                <div>Bảo trì</div>
            </div>
        </div>
    </div>

    <!-- Bộ lọc -->
    @* <div class="row g-3 mb-4">
        <div class="col-md-3">
            <input type="text" id="searchString" class="form-control" placeholder="Tìm kiếm xe..." value="@ViewBag.CurrentSearchString" />
        </div>
        <div class="col-md-2">
            <select id="loaiXe" class="form-select">
                <option value="">Loại xe</option>
                @foreach (var item in ViewBag.LoaiXeList as SelectList)
                {
                    if (item.Value == ViewBag.CurrentLoaiXe?.ToString())
                    {
                        <option value="@item.Value" selected>@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <select id="hangXe" class="form-select">
                <option value="">Hãng xe</option>
                @foreach (var item in ViewBag.HangXeList as SelectList)
                {
                    if (item.Value == ViewBag.CurrentHangXe?.ToString())
                    {
                        <option value="@item.Value" selected>@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <select id="trangThai" class="form-select">
                <option value="">Trạng thái xe</option>
                @foreach (var item in ViewBag.TrangThaiList as SelectList)
                {
                    if (item.Value == ViewBag.CurrentTrangThai?.ToString())
                    {
                        <option value="@item.Value" selected>@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <button type="button" id="filterBtn" class="btn btn-secondary">
                <i class="bi bi-funnel"></i> Lọc
            </button>
            <button type="button" id="clearFilterBtn" class="btn btn-outline-secondary" style="display: none;">
                <i class="bi bi-x-circle"></i> Xóa lọc
            </button>
        </div>
    </div> *@

    <!-- Bảng danh sách -->
    <div class="card">
        <div class="card-header">
            <h5>Danh sách xe</h5>
        </div>
        <div class="card-body" id="xeTableContainer">
            @Html.Partial("_XeTablePartial", Model)
        </div>
    </div>
</div>

