@model bikey.Models.HoaDon
@{
    @* ViewData["Title"] = $"Chi tiết hóa đơn HD{Model.MaHoaDon:D6}"; *@
    Layout = "_AdminLayout";
    ViewBag.Title = "Chi Tiết Hóa đon";
}

@section Styles{
    <link rel="stylesheet" href="~/css/hoadon/chitiet.css" asp-append-version="true"/>
}

@section Scripts {
    <script src="/js//quanlyhoadon/chitiet.js"></script>
}

<div class="container-header completed">
    <div class="invoice-header">
        <div class="invoice-number">
            <i class="bi bi-file-earmark-text"></i> HD000011
        </div>
        <div class="invoice-status">
            Đã thanh toán
        </div>
        <p class="mb-0 mt-3">Ngày tạo: 20/03/2026</p>
    </div>
</div>

<div class="container-header pending">
    <div class="invoice-header">
        <div class="invoice-number">
            <i class="bi bi-file-earmark-text"></i> HD000011
        </div>
        <div class="invoice-status">
            Đã thanh toán
        </div>
        <p class="mb-0 mt-3">Ngày tạo: 20/03/2026</p>
    </div>
</div>



<div class="wrapper">

    <div class="invoice-grid">
        @* left *@
        <div>

            <!-- Thông tin khách hàng -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-person-fill"></i> Thông tin khách hàng
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Họ và tên</div>
                            <div class="info-value">tên khách</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Số điện thoại</div>
                            <div class="info-value">0987654321</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">CCCD/CMND</div>
                            <div class="info-value">1234567890</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Địa chỉ</div>
                            <div class="info-value">Địa chỉ / Không có</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Thông tin xe -->
            <div class="info-section">
                <h3 class="section-title mb-0">
                    <i class="bi bi-bicycle"></i> Thông tin xe thuê
                </h3>

                @* @if (Model.HopDong?.ChiTietHopDong?.Any() == true)
                {*@
                <div class="vehicle-card">
                    <div class="vehicle-header">
                        <div style="font-size: 20px;"><strong>Tên xe - Biển số xe</strong></div>
                        <div> hãng xe - dòng xe</div>
                    </div>
                    <div class="vehicle-body">
                        <div class="vehicle-info-grid">
                            <div class="vehicle-info-item">
                                <div class="vehicle-info-label">Giá thuê/ngày</div>
                                <div class="vehicle-info-value">20,000đ</div>
                            </div>
                            <div class="vehicle-info-item">
                                <div class="vehicle-info-label">Số ngày thuê</div>
                                <div class="vehicle-info-value">5 ngày</div>
                            </div>
                            <div class="vehicle-info-item">
                                <div class="vehicle-info-label">Thành tiền</div>
                                <div class="vehicle-info-value">100,000đ</div>
                            </div>
                        </div>
                    </div>
                </div>
                @* }
                else
                { *@
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> Không có thông tin xe
                    </div>
                @* } *@
            </div>

            <!-- Thông tin thời gian thuê -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-calendar-range"></i> Thông tin thời gian thuê
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày nhận xe</div>
                            <div class="info-value">12/12/1212</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày trả xe thực tế</div>
                            <div class="info-value">12/12/1212</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Số ngày thuê</div>
                            <div class="info-value">1 ngày</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Giá thuê/ngày</div>
                            <div class="info-value">20,000đ</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* right *@
        <div>

            <!-- Thông tin hóa đơn -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-info-circle"></i> Thông tin hóa đơn
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Mã hóa đơn</div>
                            <div class="info-value">HD000011</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Mã hợp đồng liên quan</div>
                            <div class="info-value">
                                <a asp-controller="QuanLyHopDong" asp-action="ChiTiet"
                                   class="text-decoration-none fw-bold text-primary">
                                    HD000011
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày thanh toán</div>
                            <div class="info-value">12/12/1212</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Người tạo</div>
                            <div class="info-value">tên user / N/A</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Ghi chú -->
            @* @if (!string.IsNullOrEmpty(Model.GhiChu))
            { *@
                <div class="section-divider"></div>
                <div class="info-section">
                    <h3 class="section-title">
                        <i class="bi bi-chat-left-text"></i> Ghi chú
                    </h3>
                    <div class="info-row">
                        <div class="info-value">nội dung Ghi chú ở đây</div>
                    </div>
                </div>
            @* } *@

            <!-- Tổng kết thanh toán -->
            <div class="financial-summary completed">
                <h3>TỔNG TIỀN THANH TOÁN</h3>
                <div class="total-amount">1,000,000đ</div>
                <p class="mb-0">
                    <i class="bi bi-check-circle-fill"></i> Đã thanh toán đầy đủ
                </p>
            </div>

            <div class="financial-summary pending">
                <h3>TỔNG TIỀN THANH TOÁN</h3>
                <div class="total-amount">1,000,000đ</div>
                <p class="mb-0">
                    <i class="bi bi-exclamation-triangle"></i> Chưa thanh toán
                </p>
            </div>

            <!-- Action buttons -->
            <div class="action-section no-print">
                <a class="btn print" id="printDropdown" onclick="togglePrintDropdown(event)">
                    <i class="bi bi-printer"></i> In hóa đơn
                </a>
                <a asp-action="Index" class="btn back">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>


        </div>

    </div>




    <div class="container-fluid">
        <div class="print-only">
            <div class="section-divider"></div>
            <div class="text-center mt-4">
                <h4>CÔNG TY CHO THUÊ XE MÁY SÀI GÒN</h4>
                <p>Địa chỉ: 95/38 Nguyễn Văn Trỗi, Phường 12, Quận Phú Nhuận, TP.HCM</p>
                <p>Điện thoại: 0908.630.065 | Email: info@chothuexe.com</p>
                <p><strong>Cảm ơn quý khách đã sử dụng dịch vụ!</strong></p>
            </div>
        </div>
    </div>

</div>