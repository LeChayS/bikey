@model bikey.Models.HoaDon
@{
    @* ViewData["Title"] = $"Chi tiết hóa đơn HD{Model.MaHoaDon:D6}"; *@
    Layout = "_AdminLayout";
    ViewBag.Title = "Chi Tiết Hóa đon";
    var isPaid = string.Equals(Model.TrangThai, "Đã thanh toán", StringComparison.OrdinalIgnoreCase);
    var statusClass = isPaid ? "completed" : "pending";
    var hopDong = Model.HopDong;
    var firstCt = hopDong?.ChiTietHopDong?.FirstOrDefault();
    var ngayTraHienThi = hopDong?.NgayTraXeThucTe.HasValue == true
        ? hopDong.NgayTraXeThucTe.Value.ToString("dd/MM/yyyy")
        : hopDong?.NgayTraXeDuKien.ToString("dd/MM/yyyy");
    var paymentMessage = isPaid ? "Đã thanh toán đầy đủ" : "Chưa thanh toán đầy đủ";
}

@section Styles{
    <link rel="stylesheet" href="~/css/hoadon/chitiet.css" asp-append-version="true"/>
}

@section Scripts {
    <script>
        function togglePrintDropdown(event) {
            event?.preventDefault?.();
            window.print();
        }

        window.addEventListener('load', function () {
            var autoPrint = @(ViewBag.AutoPrint is true ? "true" : "false");
            if (autoPrint) {
                window.print();
            }
        });
    </script>
}

<div class="container-header @statusClass">
    <div class="invoice-header">
        <div class="invoice-number">
            <i class="bi bi-file-earmark-text"></i> HD@(Model.MaHoaDon.ToString("D6"))
        </div>
        <div class="invoice-status">
            @Model.TrangThai
        </div>
        <p class="mb-0 mt-3">Ngày tạo: @Model.NgayTao.ToString("dd/MM/yyyy")</p>
    </div>
</div>



<div class="wrapper">

    <div class="invoice-grid">
        @* left *@
        <div>

            <!-- Thông tin khách hàng -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-person-fill"></i> Thông tin khách hàng
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Họ và tên</div>
                            <div class="info-value">@(string.IsNullOrWhiteSpace(hopDong?.HoTenKhach) ? "Khách vãng lai" : hopDong.HoTenKhach)</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Số điện thoại</div>
                            <div class="info-value">@hopDong?.SoDienThoai</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">CCCD/CMND</div>
                            <div class="info-value">@(!string.IsNullOrWhiteSpace(hopDong?.SoCCCD) ? hopDong!.SoCCCD : "—")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Địa chỉ</div>
                            <div class="info-value">@(!string.IsNullOrWhiteSpace(hopDong?.DiaChi) ? hopDong!.DiaChi : "Không có")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Thông tin xe -->
            <div class="info-section">
                <h3 class="section-title mb-0">
                    <i class="bi bi-bicycle"></i> Thông tin xe thuê
                </h3>

                @if (hopDong?.ChiTietHopDong?.Any() == true)
                {
                    foreach (var ct in hopDong.ChiTietHopDong)
                    {
                        <div class="vehicle-card">
                            <div class="vehicle-header">
                                <div style="font-size: 20px;">
                                    <strong>@(ct.Xe?.TenXe ?? "—") - @(ct.Xe?.BienSoXe ?? "—")</strong>
                                </div>
                                <div>@(ct.Xe?.HangXe ?? "—") - @(ct.Xe?.DongXe ?? "—")</div>
                            </div>
                            <div class="vehicle-body">
                                <div class="vehicle-info-grid">
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Giá thuê/ngày</div>
                                        <div class="vehicle-info-value">@ct.GiaThueNgay.ToString("N0")đ</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Số ngày thuê</div>
                                        <div class="vehicle-info-value">@ct.SoNgayThueTinhToan ngày</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Thành tiền</div>
                                        <div class="vehicle-info-value">@ct.ThanhTienTinhToan.ToString("N0")đ</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> Không có thông tin xe
                    </div>
                }
            </div>

            <!-- Thông tin thời gian thuê -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-calendar-range"></i> Thông tin thời gian thuê
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày nhận xe</div>
                            <div class="info-value">@hopDong?.NgayNhanXe.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày trả xe thực tế</div>
                            <div class="info-value">@ngayTraHienThi</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Số ngày thuê</div>
                            <div class="info-value">@((firstCt?.SoNgayThueTinhToan ?? 0)) ngày</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Giá thuê/ngày</div>
                            <div class="info-value">@((firstCt?.GiaThueNgay ?? 0m).ToString("N0"))đ</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày trả xe dự kiến</div>
                            <div class="info-value">@Model.NgayTraXeDuKien.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* right *@
        <div>

            <!-- Thông tin hóa đơn -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-info-circle"></i> Thông tin hóa đơn
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Mã hóa đơn</div>
                            <div class="info-value">HD@(Model.MaHoaDon.ToString("D6"))</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Mã hợp đồng liên quan</div>
                            <div class="info-value">
                                <a asp-controller="HopDong" asp-action="ChiTiet" asp-route-id="@Model.MaHopDong"
                                   class="text-decoration-none fw-bold text-primary">
                                    HD@(Model.MaHopDong.ToString("D6"))
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày thanh toán</div>
                            <div class="info-value">@Model.NgayThanhToan.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Người tạo</div>
                            <div class="info-value">@(Model.NguoiTao?.Ten ?? "N/A")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Ghi chú -->
            @if (!string.IsNullOrWhiteSpace(Model.GhiChu))
            {
                <div class="section-divider"></div>
                <div class="info-section">
                    <h3 class="section-title">
                        <i class="bi bi-chat-left-text"></i> Ghi chú
                    </h3>
                    <div class="info-row">
                        <div class="info-value">@Model.GhiChu</div>
                    </div>
                </div>
            }

            <!-- Tổng kết thanh toán -->
            <div class="financial-summary @statusClass">
                <h3>TỔNG TIỀN THANH TOÁN</h3>
                <div class="total-amount">@Model.SoTien.ToString("N0")đ</div>
                <p class="mb-0">
                    <i class="bi bi-check-circle-fill"></i> @paymentMessage
                </p>
            </div>

            <!-- Action buttons -->
            <div class="action-section no-print">
                <a class="btn print" id="printDropdown" onclick="togglePrintDropdown(event)">
                    <i class="bi bi-printer"></i> In hóa đơn
                </a>
                <a asp-action="Index" class="btn back">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
</div>