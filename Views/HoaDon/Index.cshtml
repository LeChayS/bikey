                        <td>tên xe</td>
                        <td>100,000đ</td>
                        <td>10/03/2026</td>
                        <td>
                            <span class="status-badge pending">Chưa thanh toán</span>
                        </td>
                        <td>
                            <a asp-action="ChiTiet" asp-route-id=""
                                class="btn btn-sm btn-info" title="Chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href=""
