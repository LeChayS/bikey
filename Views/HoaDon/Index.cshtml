@model IEnumerable<bikey.Models.HoaDon>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý hóa đơn";
}
@section Styles{
    <link rel="stylesheet" href="~/css/hoadon/index.css" asp-append-version="true"/>
}

@section Scripts {
    <script>
        // Auto-submit form when date changes
        $('input[type="date"]').on('change', function() {
            $(this).closest('form').submit();
        });
    </script>
}

<div class="top-header">
    <h1><i class="bi bi-receipt-cutoff"></i> Quản Lý Hóa Đơn</h1>
</div>





<div class="wrapper">


    <!-- Statistics -->
    <div class="container-fluid">
        <div class="row stat-cards">
            @* card 1 *@
            <div class="col-md-4">
                <div class="stat-card orange">
                    <div>
                        <div class="stat-label">Tổng hóa đơn</div>
                        <div class="stat-value">
                            @* @ViewBag.TotalItems *@
                            12
                        </div>
                    </div>
                    <div class="stat-icon orange text-white">
                        <i class="bi bi-receipt-cutoff"></i>
                    </div>
                </div>
            </div>
            @* card 2 *@
            <div class="col-md-4">
                <div class="stat-card green">
                    <div>
                        <div class="stat-label">Tổng doanh thu</div>
                        <div class="stat-value stat-revenue">
                            @* @ViewBag.TongDoanhThu.ToString("N0")đ *@
                            120,000đ
                        </div>
                    </div>
                    <div class="stat-icon green text-white">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                </div>
            </div>
            @* Cards 3 *@
            <div class="col-md-4">
                <div class="stat-card blue">
                    <div>
                        <div class="stat-label">Hóa đơn hôm nay</div>
                        <div class="stat-value stat-count">
                            @* @ViewBag.SoHoaDonHomNay *@
                            10
                        </div>
                    </div>
                    <div class="stat-icon blue text-white">
                        <i class="bi bi-calendar-day"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>


    @* table & filter *@
    <div class="container-fluid">


        <!-- Filter -->
        <div class="filter-section">
            <form method="get" class="row g-3 align-items-center">
                <div class="col-md-3">
                    <label class="form-label">Tìm theo SĐT/Tên khách:</label>
                    <input type="text" name="searchString" class="form-control"
                        placeholder="Nhập số điện thoại hoặc tên..."
                        value="@ViewBag.SearchString" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Từ ngày:</label>
                    <input type="date" name="tuNgay" class="form-control"
                        value="@ViewBag.TuNgay?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Đến ngày:</label>
                    <input type="date" name="denNgay" class="form-control"
                        value="@ViewBag.DenNgay?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">&nbsp;</label>
                    <div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-funnel"></i> Lọc dữ liệu
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Table -->
        <div class="invoice-table">
            <table class="table table-hover mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>Mã Hóa đơn</th>
                        <th>Mã hợp đồng</th>
                        <th>Khách hàng</th>
                        <th>Xe</th>
                        <th>Số tiền</th>
                        <th>Ngày thanh toán</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @* @foreach (var hoaDon in Model)
                    {
