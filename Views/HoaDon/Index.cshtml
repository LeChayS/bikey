@model IEnumerable<bikey.Models.HoaDon>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý hóa đơn";
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = pageSize > 0 ? (int)Math.Ceiling((double)totalItems / pageSize) : 1;
    decimal tongDoanhThu = ViewBag.TongDoanhThu is decimal td ? td : 0m;
    int soHoaDonHomNay = ViewBag.SoHoaDonHomNay ?? 0;
    var tuNgayVal = ViewBag.TuNgay as DateTime?;
    var denNgayVal = ViewBag.DenNgay as DateTime?;
    var searchVal = ViewBag.SearchString as string;
}
@section Styles{
    <link rel="stylesheet" href="~/css/hoadon/index.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/shared/admin-filter-bar.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('#hoadon-filter-form input[type="date"]').forEach(function (el) {
                el.addEventListener('change', function () {
                    var f = document.getElementById('hoadon-filter-form');
                    if (f) f.requestSubmit();
                });
            });
        });
    </script>
}

<div class="top-header">
    <h1><i class="bi bi-receipt-cutoff"></i> Quản Lý Hóa Đơn</h1>
</div>

<div class="wrapper">

    <!-- Statistics -->
    <div class="container-fluid">
        <div class="row stat-cards">
            @* card 1 *@
            <div class="col-md-4">
                <div class="stat-card orange">
                    <div>
                        <div class="stat-label">Tổng hóa đơn</div>
                        <div class="stat-value">
                            @totalItems
                        </div>
                    </div>
                    <div class="stat-icon orange text-white">
                        <i class="bi bi-receipt-cutoff"></i>
                    </div>
                </div>
            </div>
            @* card 2 *@
            <div class="col-md-4">
                <div class="stat-card green">
                    <div>
                        <div class="stat-label">Tổng doanh thu</div>
                        <div class="stat-value stat-revenue">
                            @tongDoanhThu.ToString("N0")đ
                        </div>
                    </div>
                    <div class="stat-icon green text-white">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                </div>
            </div>
            @* Cards 3 *@
            <div class="col-md-4">
                <div class="stat-card blue">
                    <div>
                        <div class="stat-label">Hóa đơn hôm nay</div>
                        <div class="stat-value stat-count">
                            @soHoaDonHomNay
                        </div>
                    </div>
                    <div class="stat-icon blue text-white">
                        <i class="bi bi-calendar-day"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* table & filter *@
    <div class="container-fluid">


        <!-- Filter -->
        <div class="filter-section">
            <form id="hoadon-filter-form" method="get" asp-controller="HoaDon" asp-action="Index" class="row g-3 align-items-end filter-bar">
                    <div class="col filter-bar-field">
                        <label class="form-label" for="hoadon-search">Tìm theo SĐT/Tên khách</label>
                        <input type="search" id="hoadon-search" name="searchString" class="form-control"
                            placeholder="Số điện thoại hoặc tên..."
                            value="@searchVal" autocomplete="off" />
                    </div>
                    <div class="col filter-bar-field">
                        <label class="form-label" for="hoadon-tu-ngay">Từ ngày</label>
                        <input type="date" id="hoadon-tu-ngay" name="tuNgay" class="form-control"
                            value="@tuNgayVal?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col filter-bar-field">
                        <label class="form-label" for="hoadon-den-ngay">Đến ngày</label>
                        <input type="date" id="hoadon-den-ngay" name="denNgay" class="form-control"
                            value="@denNgayVal?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-auto filter-bar-action">
                        <label class="form-label d-block">&nbsp;</label>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-funnel"></i> Lọc dữ liệu
                        </button>
                    </div>
                    <div class="col-auto filter-bar-action">
                        <label class="form-label d-block">&nbsp;</label>
                        <a asp-controller="HoaDon" asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-clockwise"></i> Làm mới
                        </a>
                    </div>
            </form>
        </div>

        <!-- Table -->
        <div class="invoice-table">
            <table class="table table-hover mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>Mã Hóa đơn</th>
                        <th>Mã hợp đồng</th>
                        <th>Khách hàng</th>
                        <th>Xe</th>
                        <th>Số tiền</th>
                        <th>Ngày thanh toán</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var hoaDon in Model)
                        {
                            <tr>
                                <td><strong>HD@(hoaDon.MaHoaDon.ToString("D6"))</strong></td>
                                <td>
                                    <a asp-controller="HopDong" asp-action="ChiTiet" asp-route-id="@hoaDon.MaHopDong"
                                        class="text-decoration-none">
                                        HD@(hoaDon.MaHopDong.ToString("D6"))
                                    </a>
                                </td>
                                <td>
                                    @(string.IsNullOrWhiteSpace(hoaDon.HopDong?.HoTenKhach)
                                        ? "Khách vãng lai"
                                        : hoaDon.HopDong.HoTenKhach)<br />
                                    <small class="text-muted">@hoaDon.HopDong?.SoDienThoai</small>
                                </td>
                                <td>
                                    @if (hoaDon.HopDong?.ChiTietHopDong?.Any() == true)
                                    {
                                        var xeDau = hoaDon.HopDong.ChiTietHopDong.First();
                                        @xeDau.Xe?.TenXe
                                        <br />
                                        <small class="text-muted">@xeDau.Xe?.BienSoXe</small>
                                        @if (hoaDon.HopDong.ChiTietHopDong.Count > 1)
                                        {
                                            <br/><small class="text-info">+@(hoaDon.HopDong.ChiTietHopDong.Count - 1) xe khác</small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-danger">Không có xe</span>
                                    }
                                </td>
                                <td class="text-success fw-bold">@hoaDon.SoTien.ToString("N0")đ</td>
                                <td>@hoaDon.NgayThanhToan.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="status-badge">@hoaDon.TrangThai</span>
                                </td>
                                <td>
                                    <a asp-action="ChiTiet" asp-route-id="@hoaDon.MaHoaDon"
                                        class="btn btn-sm btn-info" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-controller="HoaDon" asp-action="InHoaDon" asp-route-id="@hoaDon.MaHoaDon"
                                        target="_blank" class="btn btn-sm btn-secondary" title="In hóa đơn">
                                        <i class="bi bi-printer"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">Không có hóa đơn phù hợp.</td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <nav aria-label="Page navigation" class="p-3">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new {
                                    page = i,
                                    pageSize = pageSize,
                                    searchString = searchVal,
                                    tuNgay = tuNgayVal?.ToString("yyyy-MM-dd"),
                                    denNgay = denNgayVal?.ToString("yyyy-MM-dd")
                                })">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>

    </div>
</div>