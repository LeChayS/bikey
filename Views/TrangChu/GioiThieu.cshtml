@{
    ViewData["Title"] = "Giới thiệu";
}

@section Styles {
    <link rel="stylesheet" href="~/css/trangchu/index.css" asp-append-version="true" />
}

<section class="home-hero">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <span class="badge bg-primary mb-3">Về chúng tôi</span>
                <h1>Dịch vụ cho thuê xe uy tín hàng đầu</h1>
                <p class="lead mt-3">
                    Bikey tự hào là đơn vị cung cấp dịch vụ cho thuê xe máy chất lượng cao tại TP. Hồ Chí Minh,
                    mang đến giải pháp di chuyển linh hoạt và tiện lợi cho mọi khách hàng.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="info-card text-center">
                    <div class="display-4 text-primary mb-3">
                        <i class="bi bi-award"></i>
                    </div>
                    <h3>5+ Năm kinh nghiệm</h3>
                    <p>Phục vụ hàng nghìn khách hàng với chất lượng tốt nhất</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-card text-center">
                    <div class="display-4 text-primary mb-3">
                        <i class="bi bi-people"></i>
                    </div>
                    <h3>10,000+ Khách hàng</h3>
                    <p>Đã tin tưởng và sử dụng dịch vụ của chúng tôi</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-card text-center">
                    <div class="display-4 text-primary mb-3">
                        <i class="bi bi-scooter"></i>
                    </div>
                    <h3>50+ Mẫu xe</h3>
                    <p>Đa dạng mẫu mã, phù hợp mọi nhu cầu</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h2 class="mb-4">Lịch sử hình thành</h2>
                <p>
                    Bikey được thành lập vào năm 2019 với sứ mệnh mang đến giải pháp di chuyển
                    tiện lợi, linh hoạt và kinh tế cho người dân TP. Hồ Chí Minh.
                </p>
                <p>
                    Từ những ngày đầu chỉ với 10 chiếc xe, chúng tôi đã không ngừng phát triển và
                    nâng cao chất lượng dịch vụ. Đến nay, Bikey sở hữu hơn 50 xe đa dạng mẫu mã,
                    phục vụ hàng nghìn lượt khách hàng mỗi tháng.
                </p>
            </div>
            <div class="col-lg-6">
                <div class="bg-light p-5 rounded">
                    <h3 class="mb-4">Tầm nhìn & Sứ mệnh</h3>
                    <div class="mb-4">
                        <h5><i class="bi bi-eye text-primary"></i> Tầm nhìn</h5>
                        <p>
                            Trở thành đơn vị cung cấp dịch vụ cho thuê xe hàng đầu tại Việt Nam,
                            mang đến trải nghiệm tốt nhất cho khách hàng.
                        </p>
                    </div>
                    <div>
                        <h5><i class="bi bi-bullseye text-primary"></i> Sứ mệnh</h5>
                        <p>
                            Cung cấp giải pháp di chuyển linh hoạt, an toàn và kinh tế,
                            đáp ứng mọi nhu cầu của khách hàng với dịch vụ chuyên nghiệp.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2>Giá trị cốt lõi</h2>
            <p class="text-muted">Những nguyên tắc chúng tôi luôn tuân thủ</p>
        </div>
        <div class="row g-4">
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-shield-check display-4 text-primary mb-3"></i>
                        <h5>Uy tín</h5>
                        <p class="small">Luôn đặt uy tín lên hàng đầu trong mọi giao dịch</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-star display-4 text-primary mb-3"></i>
                        <h5>Chất lượng</h5>
                        <p class="small">Xe luôn được bảo dưỡng định kỳ, đảm bảo an toàn</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-heart display-4 text-primary mb-3"></i>
                        <h5>Tận tâm</h5>
                        <p class="small">Phục vụ khách hàng với thái độ nhiệt tình, chu đáo</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-lightning display-4 text-primary mb-3"></i>
                        <h5>Nhanh chóng</h5>
                        <p class="small">Thủ tục đơn giản, giao nhận xe nhanh chóng</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2>Đội ngũ của chúng tôi</h2>
            <p class="text-muted">Những con người tận tâm phục vụ bạn</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-person fs-1"></i>
                        </div>
                        <h5>Nguyễn Văn A</h5>
                        <p class="text-muted small">Giám đốc điều hành</p>
                        <p class="small">Hơn 10 năm kinh nghiệm trong lĩnh vực cho thuê xe</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-person fs-1"></i>
                        </div>
                        <h5>Trần Thị B</h5>
                        <p class="text-muted small">Trưởng phòng kinh doanh</p>
                        <p class="small">Chuyên gia tư vấn và chăm sóc khách hàng</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-person fs-1"></i>
                        </div>
                        <h5>Lê Văn C</h5>
                        <p class="text-muted small">Trưởng phòng kỹ thuật</p>
                        <p class="small">Đảm bảo chất lượng và bảo dưỡng xe chuyên nghiệp</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>