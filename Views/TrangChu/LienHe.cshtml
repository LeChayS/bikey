@{
    ViewData["Title"] = "Liên hệ";
}

@section Styles {
    <link rel="stylesheet" href="~/css/trangchu/index.css" asp-append-version="true" />
}

<section class="home-hero">
    <div class="container">
        <div class="text-center">
            <h1>Liên hệ với chúng tôi</h1>
            <p class="lead mt-3">
                Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn. Hãy liên hệ với chúng tôi qua biểu mẫu dưới đây
                hoặc thông qua các kênh liên lạc khác.
            </p>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-7">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h2 class="mb-4">Gửi tin nhắn cho chúng tôi</h2>
                        <form id="contactForm">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="contactName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control form-control-lg" id="contactName" required />
                                </div>
                                <div class="col-md-6">
                                    <label for="contactPhone" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                                    <input type="tel" class="form-control form-control-lg" id="contactPhone" inputmode="numeric" maxlength="10" pattern="\d{10}" required />
                                </div>
                                <div class="col-12">
                                    <label for="contactEmail" class="form-label">Email <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control form-control-lg" id="contactEmail" required />
                                </div>
                                <div class="col-12">
                                    <label for="contactSubject" class="form-label">Tiêu đề</label>
                                    <input type="text" class="form-control form-control-lg" id="contactSubject" />
                                </div>
                                <div class="col-12">
                                    <label for="contactMessage" class="form-label">Nội dung <span class="text-danger">*</span></label>
                                    <textarea class="form-control" id="contactMessage" rows="5" required></textarea>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="bi bi-send"></i> Gửi tin nhắn
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <h3 class="mb-4">
                            <i class="bi bi-info-circle text-primary"></i> Thông tin liên hệ
                        </h3>
                        <div class="mb-3">
                            <h5><i class="bi bi-geo-alt-fill text-primary"></i> Địa chỉ</h5>
                            <p class="ms-4">
                                Số 806 Quốc lộ 22, ấp Mỹ Hòa 3, Xã Tân Xuân, Huyện Hóc Môn, TP. Hồ Chí Minh
                            </p>
                        </div>
                        <div class="mb-3">
                            <h5><i class="bi bi-telephone-fill text-primary"></i> Hotline</h5>
                            <p class="ms-4">
                                <a href="tel:0900090090" class="text-decoration-none">0900 090 090</a>
                            </p>
                        </div>
                        <div class="mb-3">
                            <h5><i class="bi bi-envelope-fill text-primary"></i> Email</h5>
                            <p class="ms-4">
                                <a href="mailto:support@bikey.vn" class="text-decoration-none">support@bikey.vn</a>
                            </p>
                        </div>
                        <div class="mb-3">
                            <h5><i class="bi bi-clock-fill text-primary"></i> Giờ làm việc</h5>
                            <p class="ms-4">
                                Thứ 2 - Chủ nhật: 8:00 - 20:00<br />
                                Hỗ trợ khẩn cấp 24/7
                            </p>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h3 class="mb-4">
                            <i class="bi bi-share text-primary"></i> Kết nối với chúng tôi
                        </h3>
                        <div class="d-flex gap-3">
                            <a href="#" class="btn btn-outline-primary btn-lg flex-fill">
                                <i class="bi bi-facebook"></i>
                            </a>
                            <a href="#" class="btn btn-outline-primary btn-lg flex-fill">
                                <i class="bi bi-instagram"></i>
                            </a>
                            <a href="#" class="btn btn-outline-primary btn-lg flex-fill">
                                <i class="bi bi-youtube"></i>
                            </a>
                            <a href="#" class="btn btn-outline-primary btn-lg flex-fill">
                                <i class="bi bi-tiktok"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-4">Vị trí chi nhánh chính</h2>
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="ratio ratio-21x9">
                    <div class="bg-secondary d-flex align-items-center justify-content-center text-white">
                        <div class="text-center">
                            <i class="bi bi-map display-1"></i>
                            <p class="mt-3">Bản đồ Google Maps sẽ được hiển thị ở đây</p>
                            <p class="small">Số 806 Quốc lộ 22, Hóc Môn, TP.HCM</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="text-center">
            <h2 class="mb-4">Câu hỏi thường gặp</h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                Làm thế nào để đặt xe?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Bạn có thể đặt xe trực tuyến qua website hoặc gọi hotline 0900 090 090.
                                Chúng tôi sẽ xác nhận và sắp xếp giao xe theo yêu cầu của bạn.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                Cần những giấy tờ gì để thuê xe?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Bạn cần mang theo CCCD/CMND, bằng lái xe (nếu có) và tiền cọc theo quy định.
                                Chúng tôi sẽ hướng dẫn bạn thủ tục cụ thể khi nhận xe.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                Có giao xe tận nơi không?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Có, chúng tôi hỗ trợ giao nhận xe tận nơi trong bán kính 10km từ chi nhánh.
                                Với khoảng cách xa hơn, vui lòng liên hệ để được tư vấn.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                Chính sách hủy đơn như thế nào?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Bạn có thể hủy đơn miễn phí trước 24h so với thời gian nhận xe.
                                Hủy trong vòng 24h sẽ áp dụng phí hủy theo quy định.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.getElementById('contactForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Cảm ơn bạn đã liên hệ! Chúng tôi sẽ phản hồi sớm nhất.');
            this.reset();
        });
    </script>
}