@model ChiTietXeViewModel

@{
    ViewData["Title"] = "Chi Tiet Xe";
    var coAnhThucTe = Model.HinhAnh.Count > 0;
}

<section class="bike-detail-page py-5">
    <div class="container">
        <div class="bike-detail-card">
            <div class="row g-4 align-items-start">
                <div class="col-lg-6">
                    <div class="bike-detail-gallery">
                        <div class="bike-detail-gallery__main">
                            @if (coAnhThucTe)
                            {
                                <img src="@Model.HinhAnh[0]" alt="@Model.TenXe" class="bike-detail-gallery__image" />
                            }
                            else
                            {
                                <div class="bike-detail-gallery__placeholder">
                                    <i class="bi bi-scooter"></i>
                                    <strong>@Model.TenXe</strong>
                                    <span>@Model.HangXe - @Model.DongXe</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="bike-detail-content">
                        <div class="bike-detail-title-block">
                            <div class="bike-detail-title-line"></div>
                            <h1>@Model.TenXe</h1>
                        </div>

                        <div class="bike-detail-price-card">
                            <span>Giá thuê theo ngày:</span>
                            <strong>@Model.GiaThue.ToString("N0") VNĐ / ngày</strong>
                        </div>

                        <div class="bike-detail-info-card">
                            <div class="bike-detail-info-row">
                                <span><i class="bi bi-tag"></i> Hãng xe:</span>
                                <strong>@Model.HangXe</strong>
                            </div>
                            <div class="bike-detail-info-row">
                                <span><i class="bi bi-bicycle"></i> Dòng xe:</span>
                                <strong>@Model.DongXe</strong>
                            </div>
                            <div class="bike-detail-info-row">
                                <span><i class="bi bi-grid"></i> Loại xe:</span>
                                <strong>@Model.LoaiXe</strong>
                            </div>
                            <div class="bike-detail-info-row">
                                <span><i class="bi bi-credit-card-2-front"></i> Biển số:</span>
                                <strong>@Model.BienSoXe</strong>
                            </div>
                            <div class="bike-detail-info-row">
                                <span><i class="bi bi-check-circle"></i> Trạng thái:</span>
                                <strong>
                                    <span class="status-pill @(Model.CoTheDatXe ? "success" : "pending")">@Model.TrangThaiHienThi</span>
                                </strong>
                            </div>
                        </div>

                        @if (Model.CoTheDatXe)
                        {
                            <a asp-controller="TrangChu" asp-action="Create" asp-route-maXe="@Model.MaXe" class="bike-detail-action-btn bike-detail-action-btn--primary">
                                <i class="bi bi-calendar-check"></i> Đặt xe ngay
                            </a>
                        }
                        else
                        {
                            <button type="button" class="bike-detail-action-btn bike-detail-action-btn--disabled" disabled>
                                <i class="bi bi-x-circle"></i> Xe đang được thuê
                            </button>
                        }

                        <div class="bike-detail-note-card">
                            <h2><i class="bi bi-info-circle"></i> Yêu cầu thuê xe</h2>
                            <p class="bike-detail-hotline">
                                <i class="bi bi-telephone"></i> Hotline: 0900 090 090
                            </p>

                            <ul class="bike-detail-rule-list">
                                <li>Từ 18+ mới được thuê xe</li>
                                <li>Bắt buộc phải đặt cọc khi nhận xe, trả tiền đầy đủ khi trả xe.</li>
                                <li>Giao xe tại nơi thuê, có thể phát sinh thêm phí dịch vụ.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
