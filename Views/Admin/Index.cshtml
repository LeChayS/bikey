@* @model bike.ViewModels.BaoCaoViewModel *@
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Admin Dashboard";
}

@section Styles {
    <link href="/css/admin/index.css" rel="stylesheet" asp-append-version="true">
}

@* @section Scripts {
    <script>
        // Auto refresh dashboard data every 30 seconds
        setInterval(function() {
            location.reload();
        }, 30000);
    </script>
} *@

<!-- Top Header -->
<div class="top-header">
    <h1 class="mb-0"><i class="bi bi-speedometer2"></i> Dashboard</h1>
</div>

<div class="wrapper">

    <!-- Statistics Cards -->
    <div class="container-fluid">
        <!-- row 1 -->
        <div class="row mb-4">
            @* card 1 *@
            <div class="col-lg-4 col-md-6">
                <div class="stat-card blue">
                    <div>
                        <div class="stat-label">Hợp đồng hoàn thành</div>
                        <div class="stat-value">
                            @* @Model.TongDonDatXe *@
                            23
                        </div>
                        @* @if (Model.PhanTramDonDat != 0)
                        {
                            <div class="stat-change @(Model.PhanTramDonDat > 0 ? "positive" : "negative")">
                                <i class="bi bi-arrow-@(Model.PhanTramDonDat > 0 ? "up" : "down")"></i>
                                @Math.Abs(Model.PhanTramDonDat).ToString("F1")% so với kỳ trước
                            </div>
                        } *@
                        <div>
                            tăng 30% so với kỳ trước
                        </div>
                    </div>
                    <div class="stat-icon blue text-white">
                        <i class="bi bi-calendar-check "></i>
                    </div>
                </div>
            </div>
            @* card 2 *@
            <div class="col-lg-4 col-md-6">
                <div class="stat-card orange">
                    <div>
                        <div class="stat-label">Doanh thu hôm nay</div>
                        <div class="stat-value">
                            @* @Model.DoanhThuHomNay.ToString("N0")đ *@
                            50,000đ
                        </div>
                        @* @if (Model.PhanTramDoanhThu != 0)
                        {
                            <div class="stat-change @(Model.PhanTramDoanhThu > 0 ? "positive" : "negative")">
                                <i class="bi bi-arrow-@(Model.PhanTramDoanhThu > 0 ? "up" : "down")"></i>
                                @Math.Abs(Model.PhanTramDoanhThu).ToString("F1")% so với kỳ trước
                            </div>
                        } *@
                        <div>
                            giảm 10% so với kỳ trước
                        </div>
                    </div>
                    <div class="stat-icon orange text-white">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                </div>
            </div>
            @* card 3 *@
            <div class="col-lg-4 col-md-6">
                <div class="stat-card green">
                    <div>
                        <div class="stat-label">Xe đang cho thuê</div>
                        <div class="stat-value">
                            @* @Model.XeDangChoThue *@
                            14
                        </div>
                    </div>
                    <div class="stat-icon green text-white">
                        <i class="bi bi-bicycle"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- row 2 -->
        <div class="row">
            @* card 4 *@
            <div class="col-lg-4 col-md-6">
                <div class="stat-card purple">
                    <div>
                        <div class="stat-label">Hợp đồng hoạt động</div>
                        <div class="stat-value">
                            @* @Model.HopDongHoatDong *@
                            10
                        </div>
                    </div>
                    <div class="stat-icon purple text-white">
                        <i class="bi bi-file-earmark-text"></i>
                    </div>
                </div>
            </div>
            @* card 5 *@
            <div class="col-lg-4 col-md-6">
                <div class="stat-card red">
                    <div>
                        <div class="stat-label">Khách hàng mới hôm nay</div>
                        <div class="stat-value">
                            @* @Model.KhachHangMoi *@
                            25
                        </div>
                    </div>
                    <div class="stat-icon red text-white">
                        <i class="bi bi-person-plus"></i>
                    </div>
                </div>
            </div>
            @* Cards 6 *@
            <div class="col-lg-4 col-md-6">
                <div class="stat-card pink">
                    <div>
                        <div class="stat-label">Tổng số xe</div>
                        <div class="stat-value">
                            @* @Model.TongSoXe *@
                            37
                        </div>
                    </div>
                    <div class="stat-icon pink text-white">
                        <i class="bi bi-collection"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions Section -->
    <div class="container-fluid">
        <div class="title">
            <p>Thao tác nhanh</p>
        </div>
        <div class="row g-0">
            <div class="col-12 p-0">
                <div class="row">
                    <div class="chart-cart col-md-3">
                        <a class="btn blue w-100" asp-action="Index" asp-controller="ThongKeBaoCao">
                            <i class="bi bi-bar-chart-line"></i><br>
                            Xem thống kê chi tiết
                        </a>
                    </div>
                    <div class="chart-cart col-md-3">
                        <a class="btn red w-100" asp-action="Index" asp-controller="HopDong">
                            <i class="bi bi-receipt"></i><br>
                            Quản lý hợp đồng
                        </a>
                    </div>
                    <div class="chart-cart col-md-3">
                        <a class="btn green w-100" asp-action="Index" asp-controller="HoaDon">
                            <i class="bi bi-receipt-cutoff"></i><br>
                            Quản lý hóa đơn
                        </a>
                    </div>
                    <div class="chart-cart col-md-3">
                        <a class="btn orange w-100" asp-action="Index" asp-controller="Xe">
                            <i class="bi bi-scooter"></i><br>
                            Quản lý xe
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Table ranking best bike *@
    <div class="container-fluid">
        <!-- Top xe thuê nhiều -->
        <div class="title">
            <p>Top xe được thuê nhiều nhất</p>
            <small class="text-muted">(chỉ tính hợp đồng đã hoàn thành)</small>
        </div>
        <table class="table table-hover mb-0">
            <thead class="table-primary">
                <tr>
                    <th>Xe</th>
                    <th>Biển số</th>
                    <th>Giá thuê/ngày</th>
                    <th>Trạng thái</th>
                    <th>Số lần</th>
                    <th>Doanh thu</th>
                </tr>
            </thead>
            <tbody>
                @* @foreach (var xe in Model.TopXeThueNhieu)
                {
                    <tr>
                        <td>@xe.TenXe</td>
                        <td>@xe.BienSo</td>
                        <td><span class="badge bg-primary">@xe.SoLanThue</span></td>
                        <td class="text-danger fw-bold">@xe.DoanhThu.ToString("N0")đ</td>
                    </tr>
                } *@
                <tr>
                    <td>tên của xe</td>
                    <td>biển số xe</td>
                    <td>23,000đ</td>
                    <td><span class="status-xe status-renting">Đang cho thuê</span></td>
                    <td><strong>5</strong></td>
                    <td>200,000đ</td>
                </tr>
                <tr>
                    <td>tên của xe</td>
                    <td>biển số xe</td>
                    <td>23,000đ</td>
                    <td><span class="status-xe status-ready">Sẵn sàng</span></td>
                    <td><strong>5</strong></td>
                    <td>200,000đ</td>
                </tr>
                <tr>
                    <td>tên của xe</td>
                    <td>biển số xe</td>
                    <td>23,000đ</td>
                    <td><span class="status-xe status-broken">Hư hỏng</span></td>
                    <td><strong>5</strong></td>
                    <td>200,000đ</td>
                </tr>
                <tr>
                    <td>tên của xe</td>
                    <td>biển số xe</td>
                    <td>23,000đ</td>
                    <td><span class="status-xe status-maintenance">Bảo trì</span></td>
                    <td><strong>5</strong></td>
                    <td>200,000đ</td>
                </tr>
                <tr>
                    <td colspan="6" class="text-center text-muted">
                        <i class="bi bg-info-circle"></i> Chưa có dữ liệu xe được thuê
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    @* Table recent contract *@
    <div class="container-fluid">
        <!-- Hợp đồng hoàn thành gần đây -->
        <div class="title">
            <p>Hợp đồng gần đây</p>
            <a class="btn btn-sm btn-outline-primary float-end" asp-action="Index" asp-controller="HopDong">
                <i class="bi bi-arrow-right"></i> Xem tất cả
            </a>
        </div>
        <table class="table table-hover mb-0">
            <thead class="table-primary">
                <tr>
                    <th>Khách hàng</th>
                    <th>Xe</th>
                    <th>Trạng thái</th>
                    <th>Ngày hoàn thành</th>
                    <th>Tổng tiền</th>
                </tr>
            </thead>
            <tbody>
                @* @foreach (var don in Model.DonDatGanDay)
                {
                    <tr>
                        <td>@don.TenKhach</td>
                        <td>@don.TenXe</td>
