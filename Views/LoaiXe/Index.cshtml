@model IEnumerable<bikey.Models.LoaiXe>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý loại xe";
}
@section Styles {
    <link href="~/css/loaixe/index.css" rel="stylesheet" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/loaixe/index.js"></script>
}

<!-- Top Header -->
<div class="top-header">
    <h1 class="mb-0"><i class="bi bi-tags"></i> Quản Lý Loại Xe</h1>
    <div>
        <a class="btn btn-primary"><i class="bi bi-plus-circle"></i> Thêm mới</a>
    </div>
</div>

<div class="wrapper">
        @Html.AntiForgeryToken()

        <div id="alert-container"></div>

    <div class="container-fluid">
        <div class="table-container">
            <table class="table table-hover mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>Mã loại xe</th>
                        <th>Tên loại xe</th>
                        <th>Ngày tạo</th>
                        <th>Ngày cập nhật</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @* @foreach (var item in Model)
                    { *@
                        <tr>
                            <td>1</td>
                            <td>tên loại xe</td>
                            <td>12/12/1212</td>
                            <td>12/12/1212 / -</td>
                            <td>
                                <button class="btn btn-sm btn-warning">Sửa</button>
                                <button class="btn btn-sm btn-danger">Xóa</button>
                            </td>
                        </tr>
                    @* } *@
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            <i class="bi bi-search" style="font-size:2rem;"></i>
                            <br>
                            Chưa có loại xe mới
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>

@* <!-- Create Modal -->
<div id="createModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Thêm loại xe mới</h3>
            <button class="modal-close" onclick="closeModal('createModal')">&times;</button>
        </div>
        <form id="createForm">
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label" for="createTenLoaiXe">Tên loại xe</label>
                    <input type="text" id="createTenLoaiXe" name="TenLoaiXe" class="form-input" required />
                    <span id="createTenLoaiXeError" class="validation-error"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('createModal')">Hủy</button>
                <button type="submit" class="btn btn-success">Lưu</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div id="editModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Sửa loại xe</h3>
            <button class="modal-close" onclick="closeModal('editModal')">&times;</button>
        </div>
        <form id="editForm">
            <div class="modal-body">
                <input type="hidden" id="editMaLoaiXe" name="MaLoaiXe" />
                <div class="form-group">
                    <label class="form-label" for="editTenLoaiXe">Tên loại xe</label>
                    <input type="text" id="editTenLoaiXe" name="TenLoaiXe" class="form-input" required />
                    <span id="editTenLoaiXeError" class="validation-error"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editModal')">Hủy</button>
                <button type="submit" class="btn btn-primary">Cập nhật</button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Xóa loại xe</h3>
            <button class="modal-close" onclick="closeModal('deleteModal')">&times;</button>
        </div>
        <div class="modal-body">
            <p id="deleteConfirmText"></p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeModal('deleteModal')">Hủy</button>
            <button type="button" class="btn btn-danger" onclick="confirmDelete()">Xóa</button>
        </div>
    </div>
</div> *@
