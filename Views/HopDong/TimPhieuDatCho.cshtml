@using bikey.Models.ViewModels
@model IEnumerable<bikey.Models.DatCho>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tìm Phiếu Đặt Chỗ";
    var hasSearched = ViewBag.HasSearched == true;
}

@section Styles {
    <link rel="stylesheet" href="/css/hopdong/timphieudatcho.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/shared/Components/ordercard.css" asp-append-version="true"/>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('input[name="soDienThoai"]').focus();
        });
    </script>
}


<div class="container-header">
    <div class="top-header">
        <a asp-action="Index" class="btn btn-primary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <div>
            <h2><i class="bi bi-search"></i> Tìm Phiếu Đặt Chỗ</h2>
            <p class="text-muted">Nhập số điện thoại khách hàng để tìm phiếu đặt chỗ</p>
        </div>
    </div>

    <div class="search-card">
        <form method="get" asp-action="TimPhieuDatCho" class="search-form">
            <div class="search-input-wrapper">
                <input type="tel" name="soDienThoai" class="form-control search-input" placeholder="Nhập số điện thoại"
                    value="@ViewBag.SoDienThoai" pattern="[0-9]{10,11}" required />

                <button type="submit" class="btn btn-search">
                    <span>Tìm kiếm</span>
                </button>
            </div>

            <p class="search-hint">Nhập số điện thoại khách hàng để xem danh sách phiếu đặt chỗ gần đây.</p>
        </form>
    </div>
</div>

<div class="wrapper">
    <div class="container-fluid">
        <div class="results-section">
            <h3 class="mb-3">Kết quả tìm kiếm</h3>

            @if (!hasSearched)
            {
                <div class="no-results">
                    <i class="bi bi-search" style="font-size: 60px;"></i>
                    <p class="mt-3">Nhập số điện thoại để bắt đầu tìm kiếm phiếu đặt chỗ.</p>
                </div>
            }
            else if (Model.Any())
            {
                @foreach (var phieu in Model)
                {
                    var vm = new OrderCardVM
                    {
                        Id = phieu.MaDatCho,
                        OrderCode = $"Đơn #DC{phieu.MaDatCho:D6}",
                        OrderDate = phieu.NgayDat,
                        StatusText = phieu.TrangThai,
                        CustomerName = string.IsNullOrWhiteSpace(phieu.HoTen) ? "Khách vãng lai" : phieu.HoTen,
                        Phone = phieu.SoDienThoai ?? "—",
                        Email = phieu.Email ?? "—",
                        VehicleName = phieu.Xe?.TenXe ?? "—",
                        Plate = phieu.Xe?.BienSoXe ?? "—",
                        PricePerDay = phieu.Xe?.GiaThue ?? 0,
                        TotalDays = phieu.SoNgayThue,
                        FromDate = phieu.NgayNhanXe,
                        ToDate = phieu.NgayTraXe,
                        TotalPrice = phieu.TongTienDuKien,
                        Note = phieu.GhiChu
                    };

                    @await Component.InvokeAsync("OrderCard", new { model = vm })
                }
            }
            else
            {
                <div class="no-results">
                    <i class="bi bi-inbox" style="font-size: 60px;"></i>
                    <p class="mt-3">Không tìm thấy phiếu đặt chỗ nào với số điện thoại này</p>
                </div>
            }
        </div>
    </div>
</div>
