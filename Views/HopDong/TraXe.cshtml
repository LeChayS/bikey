@model bikey.Models.HopDong
@{
    ViewBag.Title = "Xử Lý Trả Xe";
    Layout = "_AdminLayout";

    const decimal depositRate = 0.13m;
    const decimal timeFactor = 0.4m;

    var rentalDaysDuKien = Math.Max(1, (Model.NgayTraXeDuKien.Date - Model.NgayNhanXe.Date).Days);
    var tongGiaThueNgay = Model.ChiTietHopDong.Sum(ct => ct.GiaThueNgay);
    var tongTienThueXeDuKien = tongGiaThueNgay * rentalDaysDuKien;

    // Tiền cọc theo luật: max(GiaTriXe*0.13, GiaThueNgay*rentalDays*0.4)
    var tienCocTinhToan = Model.ChiTietHopDong.Sum(ct =>
    {
        var rentalDaysXeDuKien = Math.Max(1, (ct.NgayTraXeDuKien.Date - ct.NgayNhanXe.Date).Days);
        var vehicleValue = ct.Xe?.GiaTriXe ?? 0m;
        return Math.Max(vehicleValue * depositRate, ct.GiaThueNgay * rentalDaysXeDuKien * timeFactor);
    });

    // Cọc sẽ được hoàn lại nên không trừ vào "tổng tiền thanh toán".
    // Total = tiền thuê + phụ phí + phí đền bù.
    var tongTienKhachPhaiTraBanDau = Math.Max(0m, tongTienThueXeDuKien);
}

@section Styles {
    <link href="/css/hopdong/traxe.css" rel="stylesheet" asp-append-version="true" />
}

@section Scripts {
    <script src="/js/hopdong/traxe.js" asp-append-version="true"></script>
}

<div class="container-header">
    <div class="return-header">
        <div class="return-number">
            <i class="bi bi-arrow-return-left"></i> Xử Lý Trả Xe
        </div>
        <p class="mb-0">Hợp đồng: HD@(Model.MaHopDong.ToString("D6"))</p>
    </div>
</div>

<div class="wrapper">
    <div class="return-grid">
        @* left *@
        <div>
            <!-- Form trả xe -->
            <div class="info-section">
                <form asp-action="TraXe" asp-route-id="@Model.MaHopDong" method="post">
                    @* <input type="hidden" name="id" value="@Model.MaHopDong" /> *@
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="hopDongStartDate" value="@Model.NgayNhanXe.ToString("yyyy-MM-dd")" />
                    <input type="hidden" id="tongGiaThueNgay" value="@tongGiaThueNgay.ToString(System.Globalization.CultureInfo.InvariantCulture)" />

                    <div class="section-title">
                        <i class="bi bi-calendar-check"></i> Thông tin trả xe
                    </div>

                    @* thông tin ngày nhận/trả/thực tế *@
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Ngày nhận xe</label>
                                <input type="date" class="form-control" value="@Model.NgayNhanXe.ToString("yyyy-MM-dd")"
                                    readonly />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Ngày trả xe dự kiến</label>
                                <input type="date" class="form-control"
                                    value="@Model.NgayTraXeDuKien.ToString("yyyy-MM-dd")" readonly />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Ngày trả xe thực tế <span class="text-danger">*</span></label>
                                <input type="date" name="ngayTraThucTe" class="form-control"
                                    value="@Model.NgayTraXeDuKien.ToString("yyyy-MM-dd")" required
                                    onchange="calculateFinal()" />
                            </div>
                        </div>
                    </div>

                    <!-- Tính toán -->
                    <div class="calculation-section">
                        <h5 class="mb-3">Tính toán chi phí</h5>
                        <div class="calc-row">
                            <span>Số ngày thuê:</span>
                            <span id="soNgayThue">@rentalDaysDuKien ngày</span>
                        </div>
                        <div class="calc-row">
                            <span>Tiền thuê xe:</span>
                            <span id="tienThueXe">@tongTienThueXeDuKien.ToString("N0")đ</span>
                        </div>
                        <div class="calc-row">
                            <span>Tiền cọc đã thu:</span>
                            <span>@tienCocTinhToan.ToString("N0")đ</span>
                        </div>
                    </div>

                    <!-- Phụ phí -->
                    <div class="mb-3">
                        <label class="form-label">Phụ phí khác (nếu có)</label>
                        <input type="number" name="phuPhi" class="form-control cost-input" value="0"
                            placeholder="Phụ phí khác: xăng, vệ sinh, phạt trả trễ..." onchange="calculateFinal()"
                            oninput="formatOtherFeeDisplay()" id="otherFeeInput" />
                        <small class="text-muted">Ví dụ: nhập 50000 cho phí xăng</small>
                    </div>

                    <!-- Tình trạng xe -->
                    <div class="mb-3">
                        <label class="form-label">Tình trạng xe <span class="text-danger">*</span></label>
                        <select name="tinhTrangXe" class="form-control" required onchange="handleTinhTrangXeChange()"
                            id="tinhTrangXeSelect">
                            <option value="">-- Chọn tình trạng xe --</option>
                            <option value="Bình thường">Bình thường</option>
                            <option value="Có sự cố">Có sự cố</option>
                        </select>
                        <small class="text-muted">Chọn "Có sự cố" nếu xe bị hư hỏng hoặc có vấn đề</small>
                    </div>

                    <!-- Form thiệt hại (ẩn mặc định) -->
                    <div id="thietHaiForm" style="display: none;" class="mb-3">
                        <div class="card border-warning">
                            <div class="card-header bg-warning text-dark">
                                <h6 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Báo cáo thiệt hại</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Loại thiệt hại <span
                                                    class="text-danger">*</span></label>
                                            <select name="loaiThietHai" class="form-control" id="loaiThietHaiSelect">
                                                <option value="">-- Chọn loại thiệt hại --</option>
                                                <option value="Hư hỏng phụ kiện">Hư hỏng phụ kiện</option>
                                                <option value="Hư hỏng thân xe">Hư hỏng thân xe</option>
                                                <option value="Mất xe">Mất xe</option>
                                                <option value="Khác">Khác</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Ngày xảy ra <span
                                                    class="text-danger">*</span></label>
                                            <input type="date" name="ngayXayRaThietHai" class="form-control"
                                                value="@DateTime.Now.ToString("yyyy-MM-dd")" id="ngayXayRaThietHai" />
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Mô tả thiệt hại <span class="text-danger">*</span></label>
                                    <textarea name="moTaThietHai" class="form-control" rows="3"
                                        placeholder="Mô tả chi tiết thiệt hại..." id="moTaThietHaiText"></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Số tiền đền bù ước tính</label>
                                    <input type="number" name="chiPhiThietHai" class="form-control" value="0"
                                        placeholder="Số tiền đền bù ước tính..." id="chiPhiThietHai" />
                                    <small class="text-muted">Nhập 0 nếu chưa biết số tiền đền bù</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Ghi chú -->
                    <div class="mb-3">
                        <label class="form-label">Ghi chú khi trả xe</label>
                        <textarea name="ghiChu" class="form-control" rows="3"
                            placeholder="Ghi chú chung về quá trình trả xe..."></textarea>
                    </div>

                    <!-- Tổng tiền -->
                    <div class="total-section">
                        <h4>Tổng tiền thanh toán</h4>
                        <div class="total-amount" id="tongTienFinal">@tongTienKhachPhaiTraBanDau.ToString("N0")đ</div>
                        <p class="mb-0">Đã bao gồm tiền thuê và phụ phí</p>
                    </div>

                    <!-- Buttons -->
                    <div class="actions">
                        <button type="submit" class="btn complete">
                            <i class="bi bi-check-circle"></i> Hoàn Tất Trả Xe
                        </button>
                        <button class="btn back" type="button"
                            onclick="location.href='@Url.Action("Index", "HopDong")'">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </button>
                    </div>
                </form>
            </div>
        </div>
        @* right *@
        <div>
            <!-- Cảnh báo trả trễ/sớm -->
            @{
                var soNgayLech = (DateTime.Now.Date - Model.NgayTraXeDuKien.Date).Days;
            }
            @if (soNgayLech > 0)
            {
                <div class="overdue-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                    <strong>Lưu ý:</strong> Khách trả xe trễ @soNgayLech ngày so với hợp đồng.
                </div>
            }
            else if (soNgayLech < 0)
            {
                <div class="early-return-notice">
                    <i class="bi bi-info-circle"></i>
                    <strong>Thông báo:</strong> Khách trả xe sớm @Math.Abs(soNgayLech) ngày so với hợp đồng.
                </div>
            }

            <!-- Thông tin hợp đồng -->
            <div class="info-section">
                <div class="section-title">
                    <i class="bi bi-info-circle"></i> Thông tin hợp đồng
                </div>
                <div class="contract-info">
                    <div class="info-row">
                        <span class="info-label">Khách hàng:</span>
                        <span class="info-value">@(!string.IsNullOrWhiteSpace(Model.HoTenKhach) ? Model.HoTenKhach : "Khách vãng lai")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Số điện thoại:</span>
                        <span class="info-value">@(Model.SoDienThoai ?? "—")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">CCCD:</span>
                        <span class="info-value">@(Model.SoCCCD ?? "—")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Xe:</span>
                        <span class="info-value">@(Model.ChiTietHopDong.FirstOrDefault()?.Xe?.TenXe ?? "—")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Biển số:</span>
                        <span class="info-value">@(Model.ChiTietHopDong.FirstOrDefault()?.Xe?.BienSoXe ?? "—")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>