@model bikey.Models.HopDong
@{
    @* ViewData["Title"] = $"Chi tiết hợp đồng HD{Model.MaHopDong:D6}"; *@
    Layout = "_AdminLayout";
    ViewBag.Title = "Chi Tiết hợp đồng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/hopdong/chitiet.css" asp-append-version="true" />
}

@section Scripts {
    <script src="/js/hopdong/chitiet.js"></script>
}

<div class="container-header">
    <div class="contract-header">
        <div class="contract-number">
            <i class="bi bi-file-earmark-text"></i> HD@(Model.MaHopDong.ToString("D6"))
        </div>
        <div class="contract-status">
            @Model.TrangThai
        </div>
        <p class="mb-0 mt-3">Ngày tạo: @Model.NgayTao.ToString("dd/MM/yyyy")</p>
    </div>
</div>

<div class="wrapper">
    <div class="contract-grid">
        @* left *@
        <div>
            <!-- Thông tin xe -->
            <div class="info-section">
                <h3 class="section-title mb-0">
                    <i class="bi bi-bicycle"></i> Thông tin xe thuê
                </h3>

                @if (Model.ChiTietHopDong?.Any() == true)
                {
                    foreach (var chiTiet in Model.ChiTietHopDong)
                    {
                        <div class="vehicle-card">
                            <div class="vehicle-header">
                                <div style="font-size: 20px;">
                                    <strong>@(chiTiet.Xe?.TenXe ?? "—") - @(chiTiet.Xe?.BienSoXe ?? "—")</strong>
                                </div>
                                <div>@(chiTiet.Xe?.HangXe ?? "—") - @(chiTiet.Xe?.DongXe ?? "—")</div>
                            </div>
                            <div class="vehicle-body">
                                <div class="vehicle-info-grid">
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Giá thuê/ngày</div>
                                        <div class="vehicle-info-value">@chiTiet.GiaThueNgay.ToString("N0")đ</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Số ngày thuê</div>
                                        <div class="vehicle-info-value">@chiTiet.SoNgayThueTinhToan ngày</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Thành tiền</div>
                                        <div class="vehicle-info-value">@chiTiet.ThanhTienTinhToan.ToString("N0")đ</div>
                                    </div>
                                    <div class="vehicle-info-item">
                                        <div class="vehicle-info-label">Tình trạng</div>
                                        <div class="vehicle-info-value">
                                            @if (string.Equals(chiTiet.TinhTrangTraXe, "Bình thường",
                                                                                StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="status-badge status-completed">Bình thường</span>
                                            }
                                            else if (string.Equals(chiTiet.TinhTrangTraXe, "Có sự cố",
                                            StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="status-badge status-problem">Có sự cố</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-renting">Đang thuê</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-exclamation-triangle"></i> Chưa có thông tin xe
                    </div>
                }
            </div>

            <!-- Thông tin khách hàng -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-person-fill"></i> Thông tin khách hàng
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Họ và tên</div>
                            <div class="info-value">@(!string.IsNullOrWhiteSpace(Model.HoTenKhach) ? Model.HoTenKhach :
                                                                "Khách vãng lai")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Số điện thoại</div>
                            <div class="info-value">@(Model.SoDienThoai ?? "—")</div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">CCCD/CMND</div>
                            <div class="info-value">@(Model.SoCCCD ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Địa chỉ</div>
                            <div class="info-value">@(!string.IsNullOrWhiteSpace(Model.DiaChi) ? Model.DiaChi : "—")
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* right *@
        <div>
            <!-- Thời gian thuê -->
            <div class="info-section">
                <h3 class="section-title">
                    <i class="bi bi-calendar-range"></i> Thời gian thuê
                </h3>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày nhận xe</div>
                            <div class="info-value">@Model.NgayNhanXe.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Ngày trả xe dự kiến</div>
                            <div class="info-value">@Model.NgayTraXeDuKien.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    @if (Model.NgayTraXeThucTe.HasValue)
                    {
                        <div class="col-md-6">
                            <div class="info-row">
                                <div class="info-label">Ngày trả xe thực tế</div>
                                <div class="info-value">@Model.NgayTraXeThucTe.Value.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>
                    }
                    <div class="col-md-6">
                        <div class="info-row">
                            <div class="info-label">Tổng số ngày thuê</div>
                            <div class="info-value">
                                @{
                                    var tongNgayThue = Model.NgayTraXeThucTe.HasValue
                                    ? Math.Max(1, (Model.NgayTraXeThucTe.Value.Date - Model.NgayNhanXe.Date).Days)
                                    : Math.Max(1, (Model.NgayTraXeDuKien.Date - Model.NgayNhanXe.Date).Days);
                                }
                                @tongNgayThue ngày
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @{
                const decimal depositRate = 0.13m;
                const decimal timeFactor = 0.4m;

                var chiTiets = Model.ChiTietHopDong ?? new System.Collections.Generic.List<bikey.Models.ChiTietHopDong>();

                var tongTienThueXe = chiTiets.Sum(ct => ct.ThanhTienTinhToan);
                var tongPhiDenBu = chiTiets.Sum(ct => ct.PhiDenBu);
                var tongCong = tongTienThueXe + Model.PhuPhi + tongPhiDenBu;

                // Tiền cọc tính theo luật dựa trên ngày trả xe dự kiến (ổn định theo hợp đồng).
                var tienCocTinhToan = chiTiets.Sum(ct =>
                {
                    var rentalDaysDuKien = Math.Max(1, (ct.NgayTraXeDuKien.Date - ct.NgayNhanXe.Date).Days);
                    var vehicleValue = ct.Xe?.GiaTriXe ?? 0m;
                    return Math.Max(vehicleValue * depositRate, ct.GiaThueNgay * rentalDaysDuKien * timeFactor);
                });

                // Số tiền khách phải thanh toán khi trả xe: (tổng tiền - tiền cọc), clamp về 0.
                var tongTienKhachPhaiTra = Math.Max(0m, tongCong - tienCocTinhToan);
            }

            <div class="financial-summary">
                <div class="financial-row">
                    <span>Tiền thuê xe:</span>
                    <span>@tongTienThueXe.ToString("N0")đ</span>
                </div>
                <div class="financial-row">
                    <span>Tiền cọc:</span>
                    <span>@tienCocTinhToan.ToString("N0")đ</span>
                </div>
                <div class="financial-row">
                    <span>Phụ phí:</span>
                    <span>@Model.PhuPhi.ToString("N0")đ</span>
                </div>
                <div class="financial-row">
                    <span>Phí đền bù:</span>
                    <span>@tongPhiDenBu.ToString("N0")đ</span>
                </div>
                <div class="financial-row financial-total">
                    <span>Tổng cộng:</span>
                    <span>@tongCong.ToString("N0")đ</span>
                </div>
            </div>

            @if (Model.HoaDon != null)
            {
                <div class="alert alert-success mb-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-check-circle-fill"></i>
                            <strong>Đã có hóa đơn:</strong> HD@(Model.HoaDon.MaHoaDon.ToString("D6"))
                            <br />
                            <small>Ngày thanh toán: @Model.HoaDon.NgayThanhToan.ToString("dd/MM/yyyy")</small>
                        </div>
                        <a asp-controller="HoaDon" asp-action="ChiTiet" class="btn btn-success btn-sm">
                            <i class="bi bi-receipt"></i> Xem hóa đơn
                        </a>
                    </div>
                </div>
            }

            <!-- Action buttons -->
            <div class="action-section no-print">
                <a class="btn print">
                    <i class="bi bi-printer"></i> In hợp đồng
                </a>
                @if (string.Equals(Model.TrangThai, "Đang thuê", StringComparison.OrdinalIgnoreCase))
                {
                    <a asp-action="TraXe" asp-route-id="@Model.MaHopDong" class="btn return">
                        <i class="bi bi-check-circle"></i> Xử lý trả xe
                    </a>
                }
                <a asp-action="Index" class="btn back">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
</div>