        <!-- Container cho phân trang AJAX -->
        <div id="ajaxPaginationContainer" class="mt-3" style="display: none;">
            <!-- Phân trang sẽ được thêm vào đây khi lọc -->
        </div>

        <!-- Phân trang cho dữ liệu ban đầu -->
        @if (ViewBag.TotalItems > ViewBag.PageSize)
        {
            <div class="pagination-container mt-3">
                <nav aria-label="Phân trang hợp đồng">
                    <ul class="pagination justify-content-center mb-0">
                        @{
                            int totalPagesCount = (int)Math.Ceiling((double)ViewBag.TotalItems / ViewBag.PageSize);
                            int currentPageNum = ViewBag.CurrentPage;
                            int startPage = Math.Max(1, currentPageNum - 2);
                            int endPage = Math.Min(totalPagesCount, currentPageNum + 2);
                        }

                        <!-- Nút Previous -->
                        @if (currentPageNum > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { trangThai = ViewBag.TrangThai, page = currentPageNum - 1 })">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                            </li>
                        }

                        <!-- Hiển thị các trang -->
                        @if (startPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { trangThai = ViewBag.TrangThai, page = 1 })">1</a>
                            </li>
                            @if (startPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == currentPageNum)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", new { trangThai = ViewBag.TrangThai, page = i })">@i</a>
                                </li>
                            }
                        }

                        @if (endPage < totalPagesCount)
                        {
                            @if (endPage < totalPagesCount - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { trangThai = ViewBag.TrangThai, page = totalPagesCount })">@totalPagesCount</a>
                            </li>
                        }

                        <!-- Nút Next -->
                        @if (currentPageNum < totalPagesCount)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { trangThai = ViewBag.TrangThai, page = currentPageNum + 1 })">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                            </li>
                        }
                    </ul>
                </nav>

                <!-- Thông tin phân trang -->
                <div class="text-center mt-2">
                    <small class="text-muted">
                        @{
                            int startItem = (currentPageNum - 1) * ViewBag.PageSize + 1;
                            int endItem = Math.Min(currentPageNum * ViewBag.PageSize, ViewBag.TotalItems);
                        }
                        Hiển thị @startItem-@endItem trong tổng số @ViewBag.TotalItems hợp đồng
                    </small>
                </div>
            </div>
        }



    </div>

</div>

<!-- Modal tạo hóa đơn -->
<div class="modal fade" id="taoHoaDonIndexModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tạo hóa đơn thanh toán</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="taoHoaDonIndexForm">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="maHopDongIndex" />

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        <strong>Xác nhận tạo hóa đơn</strong><br />
                        Khách hàng: <span id="tenKhachHangIndex"></span><br />
                        Hóa đơn sẽ được tạo với trạng thái "<b>Đã thanh toán</b>"
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ghi chú (tùy chọn)</label>
                        <textarea id="ghiChuHoaDonIndex" class="form-control" rows="3"
                                  placeholder="Ghi chú thêm cho hóa đơn..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-success" onclick="xacNhanTaoHoaDonIndex()">
                        <i class="bi bi-check-circle"></i> Xác nhận tạo
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
