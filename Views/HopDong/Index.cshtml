@model bikey.ViewModels.HopDongIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý hợp đồng";
    int totalItems = Model.TotalItems;
    int pageSize = Model.PageSize;
    int currentPage = Model.CurrentPage;
    int totalPages = pageSize > 0 ? (int)Math.Ceiling((double)totalItems / pageSize) : 1;
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/stat-card.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/hopdong/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shared/admin-filter-bar.css" asp-append-version="true" />
    <link href="~/css/components/alert-box.css" rel="stylesheet" asp-append-version="true">
}

@section Alerts {
    @if (TempData["HopDongSuccess"] is string successMessage)
    {
        <alert-box type="success" closable="true" title="Thành công">
            @successMessage
        </alert-box>
    }
    @if (TempData["HopDongError"] is string errorMessage)
    {
        <alert-box type="danger" closable="true" title="Lỗi">
            @errorMessage
        </alert-box>
    }
}

<!-- Top Header -->
<div class="top-header">
    <h1 class="mb-0"><i class="bi bi-receipt"></i> Quản Lý Hợp Đồng</h1>
    <div>
        <a asp-action="TimPhieuDatCho" class="btn btn-primary">
            <i class="bi bi-search"></i> Tìm phiếu đặt chỗ
        </a>
        <a asp-action="LichSuKhachHang" class="btn btn-info">
            <i class="bi bi-clock-history"></i> Lịch sử khách hàng
        </a>
    </div>
</div>

<div class="wrapper">
    @* thông báo đơn chờ xử lý *@
    @if (Model.DonChoXuLy > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-check-circle me-2 mt-1" style="font-size: 28px;"></i>
            <div class="flex-grow-1">
                <strong>Có @Model.DonChoXuLy đơn đặt xe đang chờ xử lý!</strong>
                <div style="font-size:14px; opacity:0.9; margin-top:2px;">
                    Các đơn đang chờ xử lý cần được xác nhận và tạo hợp đồng.
                </div>
            </div>
            <a asp-action="DonChoXuLy" class="btn-notification me-3">
                <i class="bi bi-arrow-right"></i> Xử lý ngay
            </a>
            <button type="button" class="close-notification" data-bs-dismiss="alert">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    <!-- Statistics -->
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-3 col-md-6">
                <stat-card label="Tổng hợp đồng"
                           value="@totalItems"
                           tone="blue"
                           align="center">
                    <div class="stat-extra-container"></div>
                </stat-card>
            </div>
            <div class="col-lg-3 col-md-6">
                <a asp-action="DonChoXuLy" class="text-decoration-none">
                    <stat-card label="Đơn chờ xử lý"
                               value="@Model.DonChoXuLy"
                               tone="red"
                               align="center"
                               style="cursor: pointer; transition: all 0.3s; border: 2px solid transparent;">
                        <span class="text-muted small">Click để xử lý</span>
                    </stat-card>
                </a>
            </div>
            <div class="col-lg-3 col-md-6">
                <stat-card label="Đang thuê"
                           value="@Model.TongDangThue"
                           tone="purple"
                           align="center">
                    <div class="stat-extra-container"></div>
                </stat-card>
            </div>
            <div class="col-lg-3 col-md-6">
                <stat-card label="Hoàn thành"
                           value="@Model.TongHoanThanh"
                           tone="green"
                           align="center">
                    <div class="stat-extra-container"></div>
                </stat-card>
            </div>
        </div>
    </div>

    <!-- table & filter -->
    <div class="container-fluid">
        @* filter *@
        <div class="filter-section">
            <form method="get" asp-controller="HopDong" asp-action="Index" class="row g-3 align-items-end filter-bar">
                @{
                    var trangThaiChon = Model.TrangThai;
                }
                <div class="col filter-bar-field">
                    <label class="form-label" for="filterTrangThai">Trạng thái</label>
                    <select name="trangThai" id="filterTrangThai" class="form-select">
                        @if (string.IsNullOrEmpty(trangThaiChon))
                        {
                            <option value="" selected>Tất cả trạng thái</option>
                        }
                        else
                        {
                            <option value="">Tất cả trạng thái</option>
                        }
                        @if (trangThaiChon == "Đang thuê")
                        {
                            <option value="Đang thuê" selected>Đang thuê</option>
                        }
                        else
                        {
                            <option value="Đang thuê">Đang thuê</option>
                        }
                        @if (trangThaiChon == "Hoàn thành")
                        {
                            <option value="Hoàn thành" selected>Hoàn thành</option>
                        }
                        else
                        {
                            <option value="Hoàn thành">Hoàn thành</option>
                        }
                        @if (trangThaiChon == "Hủy")
                        {
                            <option value="Hủy" selected>Hủy</option>
                        }
                        else
                        {
                            <option value="Hủy">Hủy</option>
                        }
                    </select>
                </div>
                <div class="col filter-bar-field">
                    <label class="form-label" for="filterTuKhoa">Tìm theo tên khách hoặc tên xe</label>
                    <input type="search" name="tuKhoa" id="filterTuKhoa" class="form-control"
                        value="@Model.TuKhoa" placeholder="Ví dụ: Nguyễn, Honda, 51A…" autocomplete="off" />
                </div>
                <div class="col-auto filter-bar-action">
                    <label class="form-label d-block">&nbsp;</label>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel"></i> Lọc dữ liệu
                    </button>
                </div>
                <div class="col-auto filter-bar-action">
                    <label class="form-label d-block">&nbsp;</label>
                    <a asp-controller="HopDong" asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-clockwise"></i> Làm mới
                    </a>
                </div>
            </form>
        </div>

        <!-- Table -->
        <div class="contract-table">
            <table class="table table-hover mb-0" id="contractTable">
                <thead class="table-primary">
                    <tr>
                        <th>Mã HĐ</th>
                        <th>Khách hàng</th>
                        <th>Xe</th>
                        <th>Ngày nhận</th>
                        <th>Ngày trả</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Hóa đơn</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.HopDongList.Any())
                    {
                        @foreach (var item in Model.HopDongList)
                        {
                            var firstXe = item.ChiTietHopDong?.FirstOrDefault();
                            var tongTienHienThi = (item.ChiTietHopDong?.Sum(ct => ct.ThanhTienTinhToan) ?? 0m)
                                + item.PhuPhi
                                + (item.ChiTietHopDong?.Sum(ct => ct.PhiDenBu) ?? 0m);
                            if (tongTienHienThi <= 0)
                            {
                                tongTienHienThi = item.TongTien;
                            }
                            var statusClass = item.TrangThai switch
                            {
                                "Đang thuê" => "status-active",
                                "Hoàn thành" => "status-completed",
                                "Hủy" => "status-cancelled",
                                _ => string.Empty
                            };
                            <tr>
                                <td><strong>HD@(item.MaHopDong.ToString("D6"))</strong></td>
                                <td>
                                    @(string.IsNullOrWhiteSpace(item.HoTenKhach) ? "Khách vãng lai" : item.HoTenKhach)<br />
                                    <small class="text-muted">@item.SoDienThoai</small>
                                </td>
                                <td>
                                    @if (firstXe?.Xe != null)
                                    {
                                        @firstXe.Xe.TenXe
                                        <br />
                                        <small class="text-muted">@firstXe.Xe.BienSoXe</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa có xe</span>
                                    }
                                </td>
                                <td>@item.NgayNhanXe.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @(item.NgayTraXeThucTe?.ToString("dd/MM/yyyy") ??
                                                            item.NgayTraXeDuKien.ToString("dd/MM/yyyy"))
                                </td>
                                <td class="text-danger fw-bold">@tongTienHienThi.ToString("N0")đ</td>
                                <td><span class="status-badge @statusClass">@item.TrangThai</span></td>
                                <td>
                                    @if (item.HoaDon != null)
                                    {
                                        <a asp-controller="HoaDon" asp-action="ChiTiet" asp-route-id="@item.HoaDon.MaHoaDon"
                                            class="badge bg-success text-decoration-none"
                                            title="Xem chi tiết hóa đơn">HD@(item.HoaDon.MaHoaDon.ToString("D6"))</a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">-</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="ChiTiet" asp-route-id="@item.MaHopDong" class="btn btn-sm btn-info"
                                        title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (item.TrangThai == "Đang thuê")
                                    {
                                        <a asp-action="TraXe" asp-route-id="@item.MaHopDong" class="btn btn-sm btn-success"
                                            title="Trả xe">
                                            <i class="bi bi-check-circle"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-4 text-muted">Không có hợp đồng phù hợp.</td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (totalPages > 1)
            {
                <div class="pagination-container mt-3">
                    <nav aria-label="Phân trang hợp đồng">
                        <ul class="pagination justify-content-center mb-0">
                            @if (currentPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                        href="@Url.Action("Index", new { trangThai = Model.TrangThai, tuKhoa = Model.TuKhoa, page = currentPage - 1 })">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item disabled">
                                    <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                                </li>
                            }

                            @for (var i = 1; i <= totalPages; i++)
                            {
                                if (i == currentPage)
                                {
                                    <li class="page-item active"><span class="page-link">@i</span></li>
                                }
                                else
                                {
                                    <li class="page-item">
                                        <a class="page-link"
                                            href="@Url.Action("Index", new { trangThai = Model.TrangThai, tuKhoa = Model.TuKhoa, page = i })">@i</a>
                                    </li>
                                }
                            }

                            @if (currentPage < totalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                        href="@Url.Action("Index", new { trangThai = Model.TrangThai, tuKhoa = Model.TuKhoa, page = currentPage + 1 })">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item disabled">
                                    <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>