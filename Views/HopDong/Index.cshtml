        </a>
        <a asp-action="TimPhieuDatCho" class="btn btn-primary">
            <i class="bi bi-search"></i> Tìm phiếu đặt chỗ
        </a>
        <a asp-action="LichSuKhachHang" class="btn btn-info">
            <i class="bi bi-clock-history"></i> Lịch sử khách hàng
        </a>
    </div>
</div>


