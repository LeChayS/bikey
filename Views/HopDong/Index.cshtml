    @* Filter & table *@
    <div class="container-fluid">

        <!-- Filter -->
        <div class="filter-section">
            <form method="get" class="row g-3 align-items-center">
                <div class="col">
                    <label class="form-label">Từ ngày</label>
                    <input type="date" id="tuNgay" class="form-control" />
                </div>
                <div class="col">
                    <label class="form-label">Đến ngày</label>
                    <input type="date" id="denNgay" class="form-control" />
                </div>
                <div class="col">
                    <label class="form-label">Trạng thái</label>
                    <select id="trangThaiFilter" class="form-select">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Đang thuê" selected="@(ViewBag.TrangThai == "Đang thuê" ? "selected" : null)">Đang thuê</option>
                        <option value="Hoàn thành" selected="@(ViewBag.TrangThai == "Hoàn thành" ? "selected" : null)">Hoàn thành</option>
                        <option value="Hủy" selected="@(ViewBag.TrangThai == "Hủy" ? "selected" : null)">Hủy</option>
                    </select>
                </div>
                <div class="col">
                    <label class="form-label">&nbsp;</label>
                    <button type="button" id="btnFilter" class="btn btn-primary w-100">
                        <i class="bi bi-funnel"></i> Lọc
                    </button>
                </div>
                <div class="col">
                    <label class="form-label">&nbsp;</label>
                    <button type="button" id="btnReset" class="btn btn-secondary w-100">
                        <i class="bi bi-arrow-clockwise"></i> Làm mới
                    </button>
                </div>
            </form>

            <!-- Thông báo kết quả lọc -->
            <div id="filterResult" class="mt-3">
                <div class="alert alert-info d-flex align-items-center">
                    <i class="bi bi-info-circle me-2"></i>
                    <span id="filterMessage">thông báo lỗi nếu có</span>
                </div>
            </div>
        </div>

