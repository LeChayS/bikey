@model IEnumerable<bikey.Models.HopDong>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý hợp đồng";
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
}

@section Styles {
    <link rel="stylesheet" href="/css/hopdong/index.css" asp-append-version="true" />
}

<!-- Top Header -->
<div class="top-header">
    <h1 class="mb-0"><i class="bi bi-receipt"></i> Quản Lý Hợp Đồng</h1>
    <div>
        <a asp-action="TimPhieuDatCho" class="btn btn-primary">
            <i class="bi bi-search"></i> Tìm phiếu đặt chỗ
        </a>
        <a asp-action="LichSuKhachHang" class="btn btn-info">
            <i class="bi bi-clock-history"></i> Lịch sử khách hàng
        </a>
    </div>
</div>

<div class="wrapper">
    @if (TempData["HopDongMessage"] is string message)
    {
        <div class="alert alert-info">@message</div>
    }

    @if ((ViewBag.DonChoXuLy ?? 0) > 0)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-check-circle me-2 mt-1" style="font-size: 28px;"></i>
            <div class="flex-grow-1">
                <strong>Có @ViewBag.DonChoXuLy đơn đặt xe đang chờ xử lý!</strong>
                <div style="font-size:14px; opacity:0.9; margin-top:2px;">
                    Các đơn đang chờ xử lý cần được xác nhận và tạo hợp đồng.
                </div>
            </div>
            <a asp-action="DonChoXuLy" class="btn-notification me-3">
                <i class="bi bi-arrow-right"></i> Xử lý ngay
            </a>
            <button type="button" class="close-notification" data-bs-dismiss="alert">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    <!-- Statistics -->
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-3 col-md-6">
                <div class="stat-card blue">
                    <div class="stat-label">Tổng hợp đồng</div>
                    <div class="stat-value">@totalItems</div>
                    <div class="stat-extra-container"></div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <a asp-action="DonChoXuLy" class="text-decoration-none">
                    <div class="stat-card red"
                        style="cursor: pointer; transition: all 0.3s; border: 2px solid transparent;">
                        <div class="stat-label">Đơn chờ xử lý</div>
                        <div class="stat-value">@ViewBag.DonChoXuLy</div>
                        <span class="text-muted small">Click để xử lý</span>
                    </div>
                </a>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card purple">
                    <div class="stat-label">Đang thuê</div>
                    <div class="stat-value">@ViewBag.TongDangThue</div>
                    <div class="stat-extra-container"></div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="stat-card green">
                    <div class="stat-label">Hoàn thành</div>
                    <div class="stat-value">@ViewBag.TongHoanThanh</div>
                    <div class="stat-extra-container"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <div class="filter-section">
            <form method="get" class="row g-3 align-items-center">
                <div class="col">
                    <label class="form-label">Trạng thái</label>
                    <select name="trangThai" class="form-select">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Đang thuê" selected="@(ViewBag.TrangThai == "Đang thuê" ? "selected" : null)">
                            Đang thuê</option>
                        <option value="Hoàn thành" selected="@(ViewBag.TrangThai == "Hoàn thành" ? "selected" : null)">
                            Hoàn thành</option>
                        <option value="Hủy" selected="@(ViewBag.TrangThai == "Hủy" ? "selected" : null)">Hủy</option>
                    </select>
                </div>
                <div class="col">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel"></i> Lọc
                    </button>
                </div>
                <div class="col">
                    <label class="form-label">&nbsp;</label>
                    <a asp-action="Index" class="btn btn-secondary w-100">
                        <i class="bi bi-arrow-clockwise"></i> Làm mới
                    </a>
                </div>
            </form>
        </div>

        <!-- Table -->
        <div class="contract-table">
            <table class="table table-hover mb-0" id="contractTable">
                <thead class="table-primary">
                    <tr>
                        <th>Mã HĐ</th>
                        <th>Khách hàng</th>
                        <th>Xe</th>
                        <th>Ngày nhận</th>
                        <th>Ngày trả</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Hóa đơn</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            var firstXe = item.ChiTietHopDong?.FirstOrDefault();
                            var statusClass = item.TrangThai switch
                            {
                                "Đang thuê" => "status-active",
                                "Hoàn thành" => "status-completed",
                                "Hủy" => "status-cancelled",
                                _ => string.Empty
                            };
                            <tr>
                                <td><strong>HD@(item.MaHopDong.ToString("D6"))</strong></td>
                                <td>
                                    @(string.IsNullOrWhiteSpace(item.HoTenKhach) ? "Khách vãng lai" : item.HoTenKhach)<br />
                                    <small class="text-muted">@item.SoDienThoai</small>
                                </td>
                                <td>
                                    @if (firstXe?.Xe != null)
                                    {
                                        @firstXe.Xe.TenXe
                                        <br />
                                        <small class="text-muted">@firstXe.Xe.BienSoXe</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa có xe</span>
                                    }
                            </td>
                            <td>@item.NgayNhanXe.ToString("dd/MM/yyyy")</td>
                            <td>
                                @(item.NgayTraXeThucTe?.ToString("dd/MM/yyyy") ??
                                                            item.NgayTraXeDuKien.ToString("dd/MM/yyyy"))
                        </td>
                        <td class="text-danger fw-bold">@item.TongTien.ToString("N0")đ</td>
                        <td><span class="status-badge @statusClass">@item.TrangThai</span></td>
                        <td>
                            @if (item.HoaDon != null)
                                    {
                                        <span class="badge bg-success">HD@(item.HoaDon.MaHoaDon.ToString("D6"))</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">-</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="ChiTiet" asp-route-id="@item.MaHopDong" class="btn btn-sm btn-info"
                                        title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (item.TrangThai == "Đang thuê")
                                    {
                                        <a asp-action="TraXe" asp-route-id="@item.MaHopDong" class="btn btn-sm btn-success"
                                            title="Trả xe">
                                            <i class="bi bi-check-circle"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-4 text-muted">Không có hợp đồng phù hợp.</td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (totalPages > 1)
            {
                <div class="pagination-container mt-3">
                    <nav aria-label="Phân trang hợp đồng">
                        <ul class="pagination justify-content-center mb-0">
                            @if (currentPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                        href="@Url.Action("Index", new { trangThai = ViewBag.TrangThai, page = currentPage - 1 })">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item disabled">
                                    <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                                </li>
                            }

                            @for (var i = 1; i <= totalPages; i++)
                            {
                                if (i == currentPage)
                                {
                                    <li class="page-item active"><span class="page-link">@i</span></li>
                                }
                                else
                                {
                                    <li class="page-item">
                                        <a class="page-link"
                                            href="@Url.Action("Index", new { trangThai = ViewBag.TrangThai, page = i })">@i</a>
                                    </li>
                                }
                            }

                            @if (currentPage < totalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                        href="@Url.Action("Index", new { trangThai = ViewBag.TrangThai, page = currentPage + 1 })">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item disabled">
                                    <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>