@model IReadOnlyList<DatCho>

@{
    ViewData["Title"] = "Quan Ly Dat Cho";
}

<section class="account-page py-5">
    <div class="container">
        <div class="account-panel">
            <div class="account-panel__header">
                <span class="eyebrow">Admin panel</span>
                <h1>Quan ly don dat cho</h1>
                <p>Theo doi va duyet cac yeu cau dat xe do khach hang vua gui len he thong.</p>
            </div>

            @if (TempData["BookingAdminMessage"] is string message)
            {
                <div class="alert alert-success mt-4" role="alert">
                    @message
                </div>
            }

            <div class="order-list mt-4">
                @if (Model.Count == 0)
                {
                    <div class="profile-item">
                        <span>Trang thai</span>
                        <strong>Chua co don dat cho nao.</strong>
                    </div>
                }
                else
                {
                    @foreach (var datCho in Model)
                    {
                        <article class="booking-admin-card">
                            <div class="booking-admin-card__header">
                                <div>
                                    <h2>#@datCho.MaDatCho - @(datCho.Xe?.TenXe ?? "Xe khong ton tai")</h2>
                                    <p>@datCho.HoTen - @datCho.SoDienThoai</p>
                                </div>
                                <div class="order-meta">
                                    <span class="status-pill @(datCho.TrangThai == "Hủy" ? "danger" : datCho.TrangThai == "Đang giữ chỗ" ? "success" : "pending")">@datCho.TrangThai</span>
                                    <strong>@datCho.TongTienDuKien.ToString("N0") VND</strong>
                                </div>
                            </div>

                            <div class="booking-admin-grid">
                                <div class="profile-item">
                                    <span>Dia chi</span>
                                    <strong>@datCho.DiaChi</strong>
                                </div>
                                <div class="profile-item">
                                    <span>Can cuoc</span>
                                    <strong>@datCho.SoCanCuoc</strong>
                                </div>
                                <div class="profile-item">
                                    <span>Ngay nhan - tra</span>
                                    <strong>@datCho.NgayNhanXe.ToString("dd/MM/yyyy") - @datCho.NgayTraXe.ToString("dd/MM/yyyy")</strong>
                                </div>
                                <div class="profile-item">
                                    <span>Ngay tao don</span>
                                    <strong>@datCho.NgayDat.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(datCho.GhiChu))
                            {
                                <p class="booking-admin-note mb-0 mt-3">
                                    <strong>Ghi chu:</strong> @datCho.GhiChu
                                </p>
                            }

                            <div class="account-panel-footer mt-4">
                                <form asp-action="TuChoi" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@datCho.MaDatCho" />
                                    <button type="submit" class="btn btn-outline-danger" @(datCho.TrangThai == "Hủy" || datCho.TrangThai == "Đã xử lý" ? "disabled" : null)>Tu choi</button>
                                </form>
                                <form asp-action="Duyet" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@datCho.MaDatCho" />
                                    <button type="submit" class="btn btn-primary" @(datCho.TrangThai != "Chờ xác nhận" ? "disabled" : null)>Duyet don</button>
                                </form>
                            </div>
                        </article>
                    }
                }
            </div>
        </div>
    </div>
</section>
