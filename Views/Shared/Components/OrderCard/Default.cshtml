@using bikey.Models.ViewModels
@model OrderCardVM

<div class="order-card mb-3">
    <div class="order-header">
        <div>
            <div class="order-number">@Model.OrderCode</div>
            <div class="order-date">
                <i class="bi bi-clock"></i> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")
            </div>
        </div>
        <span class="status-badge">
            <i class="bi bi-hourglass"></i> @Model.StatusText
        </span>
    </div>

    <div class="order-body">
        <div class="info-group">
            <div class="info-label">Khách hàng</div>
            <div class="info-value">@Model.CustomerName</div>
            <div class="text-muted small">
                <i class="bi bi-telephone"></i> @Model.Phone<br />
                <i class="bi bi-envelope"></i> @Model.Email
            </div>
        </div>

        <div class="info-group">
            <div class="info-label">Xe thuê</div>
            <div class="info-value">@Model.VehicleName</div>
            <div class="text-muted small">
                Biển số: @Model.Plate<br />
                Giá: <span class="text-danger">@Model.PricePerDay.ToString("N0")đ/ngày</span>
            </div>
        </div>

        <div class="info-group">
            <div class="info-label">Thời gian thuê</div>
            <div class="info-value">@Model.TotalDays ngày</div>
            <div class="text-muted small">
                Từ: @Model.FromDate.ToString("dd/MM/yyyy")<br />
                Đến: @Model.ToDate.ToString("dd/MM/yyyy")
            </div>
        </div>

        <div class="info-group">
            <div class="info-label">Tổng tiền dự kiến</div>
            <div class="info-value text-danger">@Model.TotalPrice.ToString("N0")đ</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Note))
    {
        <div class="alert alert-info mb-3">
            <i class="bi bi-info-circle"></i> Ghi chú: @Model.Note
        </div>
    }

    <div class="order-actions">
        <form action="/HopDong/XuLyDon" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-process btn-sm">
                <i class="bi bi-check-circle"></i> Xử lý & Tạo HĐ
            </button>
        </form>

        <form action="/HopDong/HuyDon" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-cancel btn-sm">
                <i class="bi bi-x-circle"></i> Hủy đơn
            </button>
        </form>
    </div>
</div>