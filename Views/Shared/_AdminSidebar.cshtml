@using bikey.Repository
@using Microsoft.EntityFrameworkCore
@inject BikeyDbContext _context
@{
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var userId = int.TryParse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var parsedUserId)
        ? parsedUserId
        : 0;

    var permission = userId > 0
        ? await _context.PhanQuyen.AsNoTracking().FirstOrDefaultAsync(item => item.UserId == userId)
        : null;

    var canSeeDashboard = userRole == "Admin" || userRole == "Staff";
    var canSeeBaoCao = permission?.CanViewBaoCao == true || permission?.CanViewThongKe == true || permission?.CanExportBaoCao == true;
    var canSeeHopDong = permission?.CanViewHopDong == true || permission?.CanManageHopDong == true || permission?.CanCreateHopDong == true || permission?.CanEditHopDong == true || permission?.CanDeleteHopDong == true || permission?.CanPrintHopDong == true;
    var canSeeHoaDon = permission?.CanViewHoaDon == true || permission?.CanManageHoaDon == true || permission?.CanCreateHoaDon == true || permission?.CanEditHoaDon == true || permission?.CanDeleteHoaDon == true || permission?.CanPrintHoaDon == true;
    var canSeeXe = permission?.CanViewXe == true || permission?.CanManageXe == true || permission?.CanCreateXe == true || permission?.CanEditXe == true || permission?.CanDeleteXe == true;
    var canSeeLoaiXe = permission?.CanViewLoaiXe == true || permission?.CanManageLoaiXe == true || permission?.CanCreateLoaiXe == true || permission?.CanEditLoaiXe == true || permission?.CanDeleteLoaiXe == true;
    var canSeeNguoiDung = userRole == "Admin" && (permission?.CanViewUser == true || permission?.CanManageUser == true || permission?.CanCreateUser == true || permission?.CanEditUser == true || permission?.CanDeleteUser == true);
    var canSeeDonChoXuLy = canSeeHopDong || userRole == "Admin" || userRole == "Staff";
    var donChoXuLyMoiHomNay = 0;

    if (canSeeDonChoXuLy)
    {
        var homNay = DateTime.Today;
        donChoXuLyMoiHomNay = await _context.DatCho
            .AsNoTracking()
            .CountAsync(item =>
                (item.TrangThai == "Chờ xác nhận" || item.TrangThai == "Đang giữ chỗ")
                && item.NgayDat.Date == homNay);
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/shared/adminsidebar.css" asp-append-version="true" />
}

<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <h3>ADMIN PANEL</h3>
    </div>
    @if (donChoXuLyMoiHomNay > 0)
    {
        <div class="p-2 text-white" style="background: #dc3545;">
            <div class="d-flex align-items-center justify-content-between gap-2">
                <div>
                    <div class="fw-semibold small">Đơn chờ xử lý mới</div>
                    <div class="small">Hôm nay có @donChoXuLyMoiHomNay đơn mới</div>
                </div>
                <a asp-controller="HopDong" asp-action="DonChoXuLy" class="btn btn-light btn-sm">Xem</a>
            </div>
        </div>
    }
    <ul class="sidebar-menu">
        @if (canSeeDashboard)
        {
            <li>
                <a asp-page="/Admin/Index">
                    <i class="bi bi-speedometer2"></i>
                    <span class="menu-text">Dashboard</span>
                </a>
            </li>
        }

        @if (canSeeBaoCao)
        {
            <li>
                <a asp-page="/ThongKeBaoCao/Index">
                    <i class="bi bi-bar-chart-line"></i>
                    <span class="menu-text">Thống kê & Báo cáo</span>
                </a>
            </li>
        }

        @if (canSeeHopDong)
        {
            <li>
                <a asp-controller="HopDong" asp-action="Index">
                    <i class="bi bi-receipt"></i>
                    <span class="menu-text">Quản lý hợp đồng</span>
                </a>
            </li>
        }

        @if (canSeeHoaDon)
        {
            <li>
                <a asp-controller="HoaDon" asp-action="Index">
                    <i class="bi bi-receipt-cutoff"></i>
                    <span class="menu-text">Quản lý hóa đơn</span>
                </a>
            </li>
        }

        @if (canSeeXe)
        {
            <li>
                <a asp-controller="Xe" asp-action="Index">
                    <i class="bi bi-scooter"></i>
                    <span class="menu-text">Quản lý xe</span>
                </a>
            </li>
        }

        @if (canSeeLoaiXe)
        {
            <li>
                <a asp-controller="LoaiXe" asp-action="Index">
                    <i class="bi bi-tags"></i>
                    <span class="menu-text">Quản lý loại xe</span>
                </a>
            </li>
        }

        @if (canSeeNguoiDung)
        {
            <li>
                <a asp-controller="NguoiDung" asp-action="Index">
                    <i class="bi bi-people"></i>
                    <span class="menu-text">Quản lý người dùng</span>
                </a>
            </li>
        }
    </ul>
</div>