<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <h3>ADMIN PANEL</h3>
    </div>
    <ul class="sidebar-menu">
        @if (canSeeDashboard)
        {
            <li>
                <a asp-page="/Admin/Index">
                    <i class="bi bi-speedometer2"></i>
                    <span class="menu-text">Dashboard</span>
                </a>
            </li>
        }

        @if (canSeeBaoCao)
        {
            <li>
                <a asp-page="/ThongKeBaoCao/Index">
                    <i class="bi bi-bar-chart-line"></i>
                    <span class="menu-text">Thống kê & Báo cáo</span>
                </a>
            </li>
        }

        @if (canSeeHopDong)
        {
            <li>
                <a asp-controller="HopDong" asp-action="Index">
                    <i class="bi bi-receipt"></i>
                    <span class="menu-text">Quản lý hợp đồng</span>
                </a>
            </li>
        }

        @if (canSeeHoaDon)
        {
            <li>
                <a asp-controller="HoaDon" asp-action="Index">
                    <i class="bi bi-receipt-cutoff"></i>
                    <span class="menu-text">Quản lý hóa đơn</span>
                </a>
            </li>
        }

        @if (canSeeXe)
        {
            <li>
                <a asp-controller="Xe" asp-action="Index">
                    <i class="bi bi-scooter"></i>
                    <span class="menu-text">Quản lý xe</span>
                </a>
            </li>
        }

        @if (canSeeLoaiXe)
        {
            <li>
                <a asp-controller="LoaiXe" asp-action="Index">
                    <i class="bi bi-tags"></i>
                    <span class="menu-text">Quản lý loại xe</span>
                </a>
            </li>
        }

        @if (canSeeNguoiDung)
        {
            <li>
                <a asp-controller="NguoiDung" asp-action="Index">
                    <i class="bi bi-people"></i>
                    <span class="menu-text">Quản lý người dùng</span>
                </a>
            </li>
        }
    </ul>
</div>