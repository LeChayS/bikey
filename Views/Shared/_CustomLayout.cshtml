<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bikey</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" /> <!--Link icon-->
    @* <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /> *@
    @* <link rel="stylesheet" href="~/bikey.styles.css" asp-append-version="true" />  *@
    <link rel="stylesheet" href="~/css/shared/customlayout.css" />
    @RenderSection("Scripts", required: false)
    <script src="~/js/shared/customlayout.js"></script>
    @RenderSection("Styles", required: false)
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
</head>
<body>
    <nav class="navbar navbar-expand-lg main-navbar">
        <div class="container">
            <a class="navbar-brand brand-mark" asp-controller="TrangChu" asp-action="Index">
                <span class="brand-mark__icon"><i class="bi bi-scooter"></i></span>
                <span>
                    <strong>BIKEY</strong>
                    <small>Dịch vụ thuê xe</small>
                </span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TrangChu" asp-action="Index"><i class="bi bi-house-door"></i> Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TrangChu" asp-action="GioiThieu">Giới thiệu</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TrangChu" asp-action="DanhSachXe">Danh sách xe</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TrangChu" asp-action="ChiNhanh">Chi nhánh</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TrangChu" asp-action="TinTuc">Tin tức</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TrangChu" asp-action="LienHe">Liên hệ</a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item account-nav-item">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <button class="nav-link nav-button dropdown-toggle account-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="account-avatar"><i class="bi bi-person-circle"></i></span>
                                    <span>@User.Identity.Name</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end account-dropdown">
                                    <li><a class="dropdown-item" asp-page="/Account/Profile">Chỉnh sửa thông tin</a></li>
                                    <li><a class="dropdown-item" asp-page="/Account/Orders">Lịch sử đơn hàng</a></li>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="QuanLyDatCho" asp-action="Index">Quan ly dat cho</a></li>
                                    }
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="nav-link login-link" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                        }
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer" id="lien-he">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <div class="footer-badge"><i class="bi bi-scooter"></i></div>
                    <p>Công ty uy tín cho thuê xe</p>
                    <p class="mt-3">Hỗ trợ đặt xe linh hoạt cho chuyến du lịch, công tác và di chuyển hàng ngày.</p>
                </div>
                <div class="col-md-4">
                    <h3>Chính sách của chúng tôi</h3>
                    <ul>
                        <li>Chính sách và quy định</li>
                        <li>Quy định khi thuê xe</li>
                        <li>Hướng dẫn đặc cơ và thanh toán</li>
                        <li>Hỗ trợ giao nhận xe tại nơi</li>
                    </ul>
                </div>
                <div class="col-md-4" id="chi-nhanh">
                    <h3>Thông tin liên hệ</h3>
                    <h2 class="footer-company-name">Dịch vụ thuê xe</h2>
                    <div class="contact-info">
                        <p><i class="bi bi-geo-alt-fill"></i>Số 806 Quốc lộ 22, ấp Mỹ Hòa 3, Xã Tân Xuân, Huyện Hóc Môn, TP. Hồ Chí Minh</p>
                        <p><i class="bi bi-telephone-fill"></i> 0900 090 090</p>
                        <p><i class="bi bi-envelope-fill"></i> support@bikey.vn</p>
                        <p><i class="bi bi-clock-fill"></i> Hoạt động từ 8:00 - 20:00 mỗi ngày</p>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/shared/customlayout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
