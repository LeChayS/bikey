@model UserPermissionEditorViewModel
@{
    ViewData["Title"] = "Quản lý quyền người dùng";
    Layout = "_AdminLayout";
}
@section Styles {
    <link rel="stylesheet" href="/css/nguoidung/permission.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        // ===== CLICK ITEM → TOGGLE =====
        document.addEventListener("click", function (e) {
            const item = e.target.closest(".checkbox-item");
            if (!item) return;
            const checkbox = item.querySelector("input[type='checkbox']");
            if (!checkbox) return;
            // nếu click trực tiếp checkbox hoặc label → để browser xử lý
            if (e.target === checkbox || e.target.tagName.toLowerCase() === "label") {
                return;
            }
            checkbox.checked = !checkbox.checked;
            // trigger change để update nút select all
            checkbox.dispatchEvent(new Event("change", { bubbles: true }));
        });

        // ===== UPDATE NÚT CHỌN TẤT CẢ =====
        document.addEventListener("change", function (e) {
            if (e.target.type !== "checkbox") return;
            const section = e.target.closest(".permission-section");
            if (!section) return;
            const btn = section.querySelector(".btn-toggle-all");
            if (!btn) return;
            const checkboxes = section.querySelectorAll("input[type='checkbox']:not(:disabled)");
            const allChecked = [...checkboxes].every(cb => cb.checked);
            btn.textContent = allChecked ? "Bỏ chọn tất cả" : "Chọn tất cả";
        });

        // ===== CLICK NÚT CHỌN TẤT CẢ =====
        document.addEventListener("click", function (e) {
            const btn = e.target.closest(".btn-toggle-all");
            if (!btn) return;
            const section = btn.closest(".permission-section");
            const checkboxes = section.querySelectorAll("input[type='checkbox']:not(:disabled)");
            const allChecked = [...checkboxes].every(cb => cb.checked);
            checkboxes.forEach(cb => {
                cb.checked = !allChecked;
                cb.dispatchEvent(new Event("change", { bubbles: true }));
            });

        });
    </script>
}

<div class="top-header">
    <div>
        <h1 class="mb-0">Quản lý quyền người dùng</h1>
        <p class="mb-0">Thiết lập quyền hạn cho tài khoản người dùng</p>
    </div>
    <a asp-action="Index" class="btn btn-primary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<div class="wrapper">
    <div class="user-info">
        <h4>@Model.UserName</h4>
        <p>@Model.UserEmail</p>
        <small class="text-muted">Vai trò: @Model.UserRole</small>
    </div>

    <div class="container-fluid">
        <form asp-action="Permission" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />

            @foreach (var group in PermissionGroupMetadata.All)
            {
                <div class="permission-section">
                    <div class="section-header">
                        <h5><i class="bi @group.Icon"></i> @group.Title</h5>
                        <button type="button" class="btn-toggle-all">Chọn tất cả</button>
                    </div>
                    <div class="checkbox-group">
                        @foreach (var item in group.Items)
                        {
                            var checkboxId = $"perm_{group.Icon}_{item.PropertyName}";
                            var isChecked = (bool?)Model.Permissions.GetType().GetProperty(item.PropertyName)?.GetValue(Model.Permissions) ?? false;

                            <div class="checkbox-item">
                                <input type="checkbox" id="@checkboxId" name="Permissions.@item.PropertyName" value="true" @(isChecked ? "checked" : null) />
                                <label for="@checkboxId">@item.Label</label>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Lưu quyền</button>
            </div>
        </form>
    </div>
</div>
