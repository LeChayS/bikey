    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1>Quản Lý Người dùng</h1>
                <p class="mb-0">Theo dõi và quản lý tài khoản người dùng</p>
            </div>
                <a href="/QuanLyUser/Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Thêm người dùng</a>
            
        </div>
    </div>

    <div class="user-table-card p-3">
