@using bikey.Repository
@using Microsoft.EntityFrameworkCore
@inject BikeyDbContext _context
@model NguoiDungManagementViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý người dùng";

    var userId = int.TryParse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var parsedUserId)
        ? parsedUserId
        : 0;

    var permission = userId > 0
        ? await _context.PhanQuyen.AsNoTracking().FirstOrDefaultAsync(item => item.UserId == userId)
        : null;

    var canCreateUser = permission?.CanCreateUser == true;
    var canEditUser = permission?.CanEditUser == true;
    var canDeleteUser = permission?.CanDeleteUser == true;
}

@section Styles {
    <link rel="stylesheet" href="/css/nguoidung/index.css" asp-append-version="true" />
    <link href="~/css/components/alert-box.css" rel="stylesheet" asp-append-version="true">
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const editModal = document.getElementById("editUser");
            const deleteModal = document.getElementById("deleteUser");

            editModal?.addEventListener("show.bs.modal", event => {
                const button = event.relatedTarget;
                if (!button) {
                    return;
                }

                editModal.querySelector("#EditUser_Id").value = button.getAttribute("data-id") ?? "";
                editModal.querySelector("#EditUser_HoTen").value = button.getAttribute("data-name") ?? "";
                editModal.querySelector("#EditUser_Email").value = button.getAttribute("data-email") ?? "";
                editModal.querySelector("#EditUser_SoDienThoai").value = button.getAttribute("data-phone") ?? "";
                editModal.querySelector("#EditUser_DiaChi").value = button.getAttribute("data-address") ?? "";
                editModal.querySelector("#EditUser_VaiTro").value = button.getAttribute("data-role") ?? "User";
                editModal.querySelector("#EditUser_IsActive").value = button.getAttribute("data-active") ?? "true";
                editModal.querySelector("#EditUser_MatKhauMoi").value = "";
                editModal.querySelector("#EditUser_XacNhanMatKhauMoi").value = "";
            });

            deleteModal?.addEventListener("show.bs.modal", event => {
                const button = event.relatedTarget;
                if (!button) {
                    return;
                }

                deleteModal.querySelector("#DeleteUserId").value = button.getAttribute("data-id") ?? "";
                deleteModal.querySelector("#DeleteUserName").textContent = button.getAttribute("data-name") ?? "";
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<div class="top-header">
    <h1 class="mb-0"><i class="bi bi-people"></i> Quản Lý Người dùng</h1>
    @if (canCreateUser)
    {
        <div>
            <a class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createUser">
                <i class="bi bi-plus-circle"></i> Thêm người dùng
            </a>
        </div>
    }
</div>

@section Alerts {
    @if (TempData["UserManagementSuccess"] is string successMessage)
    {
        <alert-box type="success" closable="true" title="Thành công">
            @successMessage
        </alert-box>
    }
    @if (TempData["UserManagementError"] is string errorMessage)
    {
        <alert-box type="danger" closable="true" title="Lỗi">
            @errorMessage
        </alert-box>
    }
}


<div class="wrapper">
    <div class="container-fluid">
        <div class="table-container">
            <table class="table table-hover mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>ID</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>SĐT</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Online</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4">Chưa có người dùng nào.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model.Users)
                        {
                            var roleCssClass = user.VaiTro == "Admin" ? "role-admin" : user.VaiTro == "Staff" ? "role-staff" : "role-user";
                            var roleDisplay = user.VaiTro == "Admin" ? "Quản trị" : user.VaiTro == "Staff" ? "Nhân viên" : "Khách hàng";
                            var isOnline = Model.OnlineUserIds.Contains(user.Id);

                            <tr>
                                <td>#@user.Id</td>
                                <td>@user.Ten</td>
                                <td>@user.Email</td>
                                <td>@user.SoDienThoai</td>
                                <td>
                                    <span class="role-badge @roleCssClass">@roleDisplay</span>
                                </td>
                                <td>
                                    <span class="status-badge @(user.IsActive ? "status-active" : "status-inactive")">
                                        @(user.IsActive ? "Hoạt động" : "Khóa")
                                    </span>
                                </td>
                                <td>
                                    <span class="status-badge @(isOnline ? "status-online" : "status-offline")">
                                        @(isOnline ? "Online" : "Offline")
                                    </span>
                                </td>
                                <td>@user.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (canEditUser && (user.Id != 1 || userId == 1))
                                    {
                                        <button type="button"
                                                class="btn btn-warning btn-sm btn-action"
                                                title="Sửa"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editUser"
                                                data-id="@user.Id"
                                                data-name="@user.Ten"
                                                data-email="@user.Email"
                                                data-phone="@user.SoDienThoai"
                                                data-address="@user.DiaChi"
                                                data-role="@user.VaiTro"
                                                data-active="@user.IsActive.ToString().ToLowerInvariant()">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }
                                    else if (canEditUser && user.Id == 1)
                                    {
                                        <button type="button" class="btn btn-warning btn-sm btn-action" disabled title="Tài khoản admin mặc định chỉ được chỉnh bởi chính chủ">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }

                                    @if (canEditUser)
                                    {
                                        if (user.Id == 1 && userId != 1)
                                        {
                                            <button type="button" class="btn btn-info btn-sm btn-action" disabled title="Tài khoản admin mặc định chỉ được phân quyền bởi chính chủ">
                                                <i class="bi bi-shield-lock"></i>
                                            </button>
                                        }
                                        else if (user.Id == userId)
                                        {
                                            <button type="button" class="btn btn-info btn-sm btn-action" disabled title="Không thể phân quyền cho chính mình">
                                                <i class="bi bi-shield-lock"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <a asp-action="Permission" asp-route-id="@user.Id" class="btn btn-info btn-sm btn-action" title="Phân quyền">
                                                <i class="bi bi-shield-check"></i>
                                            </a>
                                        }
                                    }

                                    @if (canDeleteUser)
                                    {
                                        <button type="button"
                                                class="btn btn-danger btn-sm btn-action"
                                                title="@(user.Id == 1 ? "Tài khoản admin mặc định không thể xóa" : user.Id == userId ? "Không thể xóa tài khoản đang đăng nhập" : isOnline ? "Không thể xóa tài khoản đang hoạt động" : "Xóa")"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteUser"
                                                data-id="@user.Id"
                                                data-name="@user.Ten"
                                                @(user.Id == 1 || user.Id == userId || isOnline ? "disabled" : null)>
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createUser" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus"></i> Thêm người dùng mới</h5>
                <button type="button" class="btn-close  btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="CreateUser_HoTen" class="form-label">Họ và tên *</label>
                        <input id="CreateUser_HoTen" name="HoTen" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label for="CreateUser_Email" class="form-label">Email *</label>
                        <input id="CreateUser_Email" name="Email" class="form-control" type="email" required />
                    </div>
                    <div class="mb-3">
                        <label for="CreateUser_SoDienThoai" class="form-label">Số điện thoại *</label>
                        <input id="CreateUser_SoDienThoai" name="SoDienThoai" class="form-control" maxlength="10" pattern="[0-9]{10}" required />
                    </div>
                    <div class="mb-3">
                        <label for="CreateUser_MatKhau" class="form-label">Mật khẩu *</label>
                        <input id="CreateUser_MatKhau" name="MatKhau" class="form-control" type="password" required />
                    </div>
                    <div class="mb-3">
                        <label for="CreateUser_XacNhanMatKhau" class="form-label">Xác nhận mật khẩu *</label>
                        <input id="CreateUser_XacNhanMatKhau" name="XacNhanMatKhau" class="form-control" type="password" required />
                    </div>
                    <div class="mb-3">
                        <label for="CreateUser_VaiTro" class="form-label">Quyền *</label>
                        <select id="CreateUser_VaiTro" name="VaiTro" class="form-select" required asp-items="ViewBag.Roles"></select>
                    </div>
                    <div class="modal-footer px-0 pb-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Thêm người dùng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editUser" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square"></i> Sửa thông tin người dùng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="EditUser_Id" name="Id" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="EditUser_HoTen" class="form-label">Họ và tên *</label>
                            <input id="EditUser_HoTen" name="HoTen" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label for="EditUser_Email" class="form-label">Email *</label>
                            <input id="EditUser_Email" name="Email" class="form-control" type="email" required />
                        </div>
                        <div class="col-md-6">
                            <label for="EditUser_SoDienThoai" class="form-label">Số điện thoại</label>
                            <input id="EditUser_SoDienThoai" name="SoDienThoai" class="form-control" maxlength="10" pattern="[0-9]{10}" />
                        </div>
                        <div class="col-md-6">
                            <label for="EditUser_DiaChi" class="form-label">Địa chỉ</label>
                            <input id="EditUser_DiaChi" name="DiaChi" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="EditUser_MatKhauMoi" class="form-label">Mật khẩu mới</label>
                            <input id="EditUser_MatKhauMoi" name="MatKhauMoi" class="form-control" type="password" placeholder="Để trống nếu không đổi" />
                        </div>
                        <div class="col-md-6">
                            <label for="EditUser_XacNhanMatKhauMoi" class="form-label">Xác nhận mật khẩu</label>
                            <input id="EditUser_XacNhanMatKhauMoi" name="XacNhanMatKhauMoi" class="form-control" type="password" placeholder="Để trống nếu không đổi" />
                        </div>
                        <div class="col-md-6">
                            <label for="EditUser_VaiTro" class="form-label">Quyền *</label>
                            <select id="EditUser_VaiTro" name="VaiTro" class="form-select" required asp-items="ViewBag.Roles"></select>
                        </div>
                        <div class="col-md-6">
                            <label for="EditUser_IsActive" class="form-label">Trạng thái</label>
                            <select id="EditUser_IsActive" name="IsActive" class="form-select">
                                <option value="true">Hoạt động</option>
                                <option value="false">Khóa</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer px-0 pb-0 mt-4">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteUser" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-circle"></i> Xóa người dùng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <h5>Bạn có chắc chắn muốn xóa người dùng <span id="DeleteUserName"></span>?</h5>
                <small class="text-muted">Tài khoản bị xóa sẽ không thể khôi phục lại được</small>
            </div>
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="DeleteUserId" name="id" />
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-danger"><i class="bi bi-check-circle"></i> Xóa người dùng</button>
                </div>
            </form>
        </div>
    </div>
</div>